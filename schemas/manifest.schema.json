{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "manifest.schema.json",
  "title": "LevelManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "workId", "level", "chapters"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "workId": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "level": { "enum": ["a2", "b1", "b2", "c1"] },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "number", "title", "sentenceCount"],
        "properties": {
          "id": { "type": "string", "pattern": "^chapter-[0-9]{3,}$" },
          "number": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "sentenceCount": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
