{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "chapter.schema.json",
  "title": "Chapter",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "workId", "level", "chapter", "paragraphs"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "workId": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "level": { "enum": ["a1", "a2", "b1", "b1v2", "b2", "c1", "c2"] },
    "chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "number", "title"],
      "properties": {
        "id": { "type": "string", "pattern": "^chapter-[0-9]{3,}$" },
        "number": { "type": "integer", "minimum": 1 },
        "title": { "type": "string", "minLength": 1 }
      }
    },
    "paragraphs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "sentences"],
        "properties": {
          "id": { "type": "string", "pattern": "^para-[0-9]{3,}$" },
          "sentences": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "text", "translationRu"],
              "properties": {
                "id": { "type": "string", "pattern": "^sent-[0-9]{3,}$" },
                "text": { "type": "string", "minLength": 1 },
                "translationRu": { "type": "string", "minLength": 1 },
                "heading": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}
