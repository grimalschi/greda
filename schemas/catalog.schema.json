{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "catalog.schema.json",
  "title": "Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "works"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "works": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "titleRu",
          "originalTitle",
          "authorId",
          "authorName",
          "genres",
          "levels",
          "availableLevels"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "lang": { "enum": ["es", "ro"] },
          "title": { "type": "string", "minLength": 1 },
          "titleRu": { "type": "string", "minLength": 1 },
          "originalTitle": { "type": "string", "minLength": 1 },
          "authorId": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "authorName": { "type": "string", "minLength": 1 },
          "genres": { "type": "array", "items": { "type": "string" } },
          "levels": {
            "type": "array",
            "items": { "enum": ["a1", "a2", "b1", "b1v2", "b2", "c1", "c2"] }
          },
          "availableLevels": {
            "type": "array",
            "items": { "enum": ["a1", "a2", "b1", "b1v2", "b2", "c1", "c2"] }
          },
          "chapters": { "type": "integer", "minimum": 0 },
          "words": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "a1": { "type": "integer", "minimum": 0 },
              "a2": { "type": "integer", "minimum": 0 },
              "b1": { "type": "integer", "minimum": 0 },
              "b1v2": { "type": "integer", "minimum": 0 },
              "b2": { "type": "integer", "minimum": 0 },
              "c1": { "type": "integer", "minimum": 0 },
              "c2": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
