{
  "schemaVersion": "1.0",
  "workId": "within-the-nebula",
  "level": "a1",
  "chapter": {
    "id": "chapter-004",
    "number": 4,
    "title": "Capítulo 4"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Sar Than tiene un plan.",
          "translationRu": "Сар Тан придумал план."
        },
        {
          "id": "sent-002",
          "text": "Esperamos al guardia.",
          "translationRu": "Мы ждём стражника."
        },
        {
          "id": "sent-003",
          "text": "Cuando pasa por el pozo, lo agarramos.",
          "translationRu": "Когда он проходит мимо ямы, мы его хватаем."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "El guardia cae dentro del pozo.",
          "translationRu": "Стражник падает в яму."
        },
        {
          "id": "sent-005",
          "text": "Luchamos contra él.",
          "translationRu": "Мы сражаемся с ним."
        },
        {
          "id": "sent-006",
          "text": "Jor Dahat lo mata.",
          "translationRu": "Джор Дахат убивает его."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Salimos del pozo con una escalera.",
          "translationRu": "Мы выбираемся из ямы по лестнице."
        },
        {
          "id": "sent-008",
          "text": "Corremos por el corredor.",
          "translationRu": "Мы бежим по коридору."
        },
        {
          "id": "sent-009",
          "text": "Vemos guardias y nos escondemos.",
          "translationRu": "Мы видим стражников и прячемся."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Encontramos una máquina tortuga vacía.",
          "translationRu": "Мы находим пустую машину-черепаху."
        },
        {
          "id": "sent-011",
          "text": "Entramos dentro.",
          "translationRu": "Мы залезаем внутрь."
        },
        {
          "id": "sent-012",
          "text": "La movemos por la gran caverna.",
          "translationRu": "Мы едем на ней через большую пещеру."
        },
        {
          "id": "sent-013",
          "text": "Los seres no nos ven.",
          "translationRu": "Существа нас не замечают."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-014",
          "text": "Llegamos al pozo largo que sube arriba.",
          "translationRu": "Мы добираемся до длинной шахты, ведущей наверх."
        },
        {
          "id": "sent-015",
          "text": "Subimos rápido.",
          "translationRu": "Мы быстро поднимаемся."
        },
        {
          "id": "sent-016",
          "text": "Un ser nos persigue.",
          "translationRu": "Одно существо преследует нас."
        },
        {
          "id": "sent-017",
          "text": "Sar Than lo empuja y cae.",
          "translationRu": "Сар Тан его толкает, и существо падает."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-018",
          "text": "Llegamos al fondo del gran agujero.",
          "translationRu": "Мы добираемся до дна большой ямы."
        },
        {
          "id": "sent-019",
          "text": "Vemos nuestra nave.",
          "translationRu": "Мы видим наш корабль."
        },
        {
          "id": "sent-020",
          "text": "Hay pocos seres aquí.",
          "translationRu": "Здесь мало существ."
        }
      ]
    },
    {
      "id": "para-007",
      "sentences": [
        {
          "id": "sent-021",
          "text": "Matamos a los guardias con hachas.",
          "translationRu": "Мы убиваем стражников топорами."
        },
        {
          "id": "sent-022",
          "text": "Yo corto el cable del cilindro grande.",
          "translationRu": "Я перерубаю кабель большого цилиндра."
        },
        {
          "id": "sent-023",
          "text": "El cable lleva la energía al rayo.",
          "translationRu": "Кабель доставляет энергию к лучу."
        }
      ]
    },
    {
      "id": "para-008",
      "sentences": [
        {
          "id": "sent-024",
          "text": "El rayo para.",
          "translationRu": "Луч останавливается."
        },
        {
          "id": "sent-025",
          "text": "Sin el rayo, la nebulosa empieza a colapsar.",
          "translationRu": "Без луча туманность начинает сжиматься."
        },
        {
          "id": "sent-026",
          "text": "El fuego baja hacia el planeta.",
          "translationRu": "Огонь опускается к планете."
        },
        {
          "id": "sent-027",
          "text": "Entramos en la nave y escapamos.",
          "translationRu": "Мы запрыгиваем в корабль и спасаемся."
        }
      ]
    },
    {
      "id": "para-009",
      "sentences": [
        {
          "id": "sent-028",
          "text": "Volamos fuera de la nebulosa.",
          "translationRu": "Мы вылетаем из туманности."
        },
        {
          "id": "sent-029",
          "text": "La nebulosa se rompe y desaparece.",
          "translationRu": "Туманность разрушается и исчезает."
        },
        {
          "id": "sent-030",
          "text": "Volvemos a Canopus como héroes.",
          "translationRu": "Мы возвращаемся на Канопус как герои."
        },
        {
          "id": "sent-031",
          "text": "El universo está a salvo.",
          "translationRu": "Вселенная спасена."
        }
      ]
    }
  ]
}
