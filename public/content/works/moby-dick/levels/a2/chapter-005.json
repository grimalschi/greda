{
  "schemaVersion": "1.0",
  "workId": "moby-dick",
  "level": "a2",
  "chapter": {
    "id": "chapter-005",
    "number": 5,
    "title": "El peligro en el agua"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Una tarde, el cielo se oscureció.",
          "translationRu": "Одним днём небо потемнело."
        },
        {
          "id": "sent-002",
          "text": "Había una tormenta que se acercaba.",
          "translationRu": "Приближалась буря."
        },
        {
          "id": "sent-003",
          "text": "A pesar del peligro, Ahab ordenó bajar los botes.",
          "translationRu": "Несмотря на опасность, Ахаб приказал спустить лодки."
        },
        {
          "id": "sent-004",
          "text": "Subí a un bote con Queequeg y otros marineros.",
          "translationRu": "Я поднялся в лодку с Кикегом и другими моряками."
        },
        {
          "id": "sent-005",
          "text": "El agua estaba muy fría y oscura.",
          "translationRu": "Вода была очень холодной и тёмной."
        },
        {
          "id": "sent-006",
          "text": "De repente, sentimos un golpe fuerte.",
          "translationRu": "Внезапно мы почувствовали сильный удар."
        },
        {
          "id": "sent-007",
          "text": "Un brazo enorme salió del agua.",
          "translationRu": "Огромный кит появился из воды."
        },
        {
          "id": "sent-008",
          "text": "Era una ballena furiosa.",
          "translationRu": "Это был разъярённый кит."
        },
        {
          "id": "sent-009",
          "text": "La ballena golpeó nuestro bote con su cola.",
          "translationRu": "Кит ударил нашу лодку хвостом."
        },
        {
          "id": "sent-010",
          "text": "Caímos al agua helada.",
          "translationRu": "Мы упали в ледяную воду."
        },
        {
          "id": "sent-011",
          "text": "Queequeg me salvó.",
          "translationRu": "Кикег спас меня."
        },
        {
          "id": "sent-012",
          "text": "Nadó hacia mí rápidamente.",
          "translationRu": "Он быстро поплыл ко мне."
        },
        {
          "id": "sent-013",
          "text": "Me agarró con sus brazos fuertes.",
          "translationRu": "Он схватил меня сильными руками."
        },
        {
          "id": "sent-014",
          "text": "Nos subimos al bote de rescate.",
          "translationRu": "Мы поднялись в спасательную лодку."
        },
        {
          "id": "sent-015",
          "text": "La tormenta se calmó poco a poco.",
          "translationRu": "Буря постепенно затихла."
        },
        {
          "id": "sent-016",
          "text": "Estábamos vivos, pero muy asustados.",
          "translationRu": "Мы были живы, но очень испуганы."
        }
      ]
    }
  ]
}
