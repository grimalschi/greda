{
  "schemaVersion": "1.0",
  "workId": "moby-dick",
  "level": "a2",
  "chapter": {
    "id": "chapter-008",
    "number": 8,
    "title": "La persecución"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Un día gritaron desde la cofa del mástil.",
          "translationRu": "Один день закричали с вершины мачты."
        },
        {
          "id": "sent-002",
          "text": "\"¡Ballena blanca a la vista!\"",
          "translationRu": "«Белый кит в поле зрения!»"
        },
        {
          "id": "sent-003",
          "text": "Todos corrimos hacia la cubierta.",
          "translationRu": "Все мы побежали на палубу."
        },
        {
          "id": "sent-004",
          "text": "Era Moby Dick.",
          "translationRu": "Это был Белый Кит."
        },
        {
          "id": "sent-005",
          "text": "La ballena era mucho más grande de lo que imaginaba.",
          "translationRu": "Кит был намного больше, чем я себе представлял."
        },
        {
          "id": "sent-006",
          "text": "Su cuerpo era blanco como la nieve.",
          "translationRu": "Его тело было белым, как снег."
        },
        {
          "id": "sent-007",
          "text": "Nadie pudo apartar la vista.",
          "translationRu": "Никто не мог отвести взгляд."
        },
        {
          "id": "sent-008",
          "text": "Ahab bajó los botes inmediatamente.",
          "translationRu": "Ахаб немедленно спустил лодки."
        },
        {
          "id": "sent-009",
          "text": "Remamos tan rápido como pudimos.",
          "translationRu": "Мы гребли так быстро, как могли."
        },
        {
          "id": "sent-010",
          "text": "La ballena nadaba lejos de nosotros.",
          "translationRu": "Кит плыл далеко от нас."
        },
        {
          "id": "sent-011",
          "text": "Moby Dick era muy rápido.",
          "translationRu": "Белый Кит был очень быстрым."
        },
        {
          "id": "sent-012",
          "text": "Aún así, continuamos la persecución.",
          "translationRu": "Всё же мы продолжили преследование."
        },
        {
          "id": "sent-013",
          "text": "El grito de Ahab era terrible y obsesivo.",
          "translationRu": "Крик Ахаба был ужасным и одержимым."
        },
        {
          "id": "sent-014",
          "text": "Todos lo seguían sin dudarlo.",
          "translationRu": "Все следовали за ним без сомнений."
        },
        {
          "id": "sent-015",
          "text": "Sabíamos que algo terrible iba a suceder pronto.",
          "translationRu": "Мы знали, что что-то ужасное произойдёт очень скоро."
        }
      ]
    }
  ]
}
