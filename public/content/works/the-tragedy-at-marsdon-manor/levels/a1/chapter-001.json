{
  "schemaVersion": "1.0",
  "workId": "the-tragedy-at-marsdon-manor",
  "level": "a1",
  "chapter": {
    "id": "chapter-001",
    "number": 1,
    "title": "Tragedia de la conacul Marsdon"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Eu sunt Hastings.",
          "translationRu": "Я Гастингс.",
          "original": "I am Hastings."
        },
        {
          "id": "sent-002",
          "text": "Prietenul meu Poirot este detectiv.",
          "translationRu": "Мой друг Пуаро — детектив.",
          "original": "My friend Poirot is a detective."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-003",
          "text": "Într-o zi, a venit o scrisoare.",
          "translationRu": "Однажды пришло письмо.",
          "original": "One day a letter came."
        },
        {
          "id": "sent-004",
          "text": "Era de la o companie de asigurări.",
          "translationRu": "Оно было от страховой компании.",
          "original": "It was from an insurance company."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-005",
          "text": "Compania scrie despre un om bogat.",
          "translationRu": "Компания пишет о богатом человеке.",
          "original": "The company writes about a rich man."
        },
        {
          "id": "sent-006",
          "text": "Numele lui este domnul Maltravers.",
          "translationRu": "Его зовут господин Малтраверс.",
          "original": "His name is Mr. Maltravers."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Domnul Maltravers nu mai avea bani.",
          "translationRu": "У господина Малтраверса больше не было денег.",
          "original": "Mr. Maltravers had no money left."
        },
        {
          "id": "sent-008",
          "text": "El a asigurat viața lui.",
          "translationRu": "Он застраховал свою жизнь.",
          "original": "He insured his life."
        },
        {
          "id": "sent-009",
          "text": "A asigurat-o pentru mulți bani.",
          "translationRu": "Застраховал её на большие деньги.",
          "original": "He insured it for a lot of money."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Apoi a murit foarte repede.",
          "translationRu": "Потом он умер очень быстро.",
          "original": "Then he died very quickly."
        },
        {
          "id": "sent-011",
          "text": "Compania crede că ceva nu este bine.",
          "translationRu": "Компания думает, что что-то не так.",
          "original": "The company thinks something is wrong."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Poirot spune: mergem acolo.",
          "translationRu": "Пуаро говорит: едем туда.",
          "original": "Poirot says: we go there."
        },
        {
          "id": "sent-013",
          "text": "Mergem la conacul Marsdon.",
          "translationRu": "Едем в поместье Марсдон.",
          "original": "We go to Marsdon Manor."
        }
      ]
    },
    {
      "id": "para-007",
      "sentences": [
        {
          "id": "sent-014",
          "text": "Conacul este mare și vechi.",
          "translationRu": "Поместье большое и старое.",
          "original": "The manor is big and old."
        },
        {
          "id": "sent-015",
          "text": "În casă locuiește soția.",
          "translationRu": "В доме живёт жена.",
          "original": "The wife lives in the house."
        },
        {
          "id": "sent-016",
          "text": "Ea este tânără și frumoasă.",
          "translationRu": "Она молодая и красивая.",
          "original": "She is young and beautiful."
        },
        {
          "id": "sent-017",
          "text": "Acum este văduvă.",
          "translationRu": "Теперь она вдова.",
          "original": "Now she is a widow."
        }
      ]
    },
    {
      "id": "para-008",
      "sentences": [
        {
          "id": "sent-018",
          "text": "Doamna Maltravers este tristă.",
          "translationRu": "Госпожа Малтраверс грустна.",
          "original": "Mrs. Maltravers is sad."
        },
        {
          "id": "sent-019",
          "text": "Ea spune: soțul meu era bolnav.",
          "translationRu": "Она говорит: мой муж был болен.",
          "original": "She says: my husband was ill."
        },
        {
          "id": "sent-020",
          "text": "A căzut afară, în grădină.",
          "translationRu": "Он упал снаружи, в саду.",
          "original": "He fell outside, in the garden."
        },
        {
          "id": "sent-021",
          "text": "Pe buze avea sânge.",
          "translationRu": "На губах у него была кровь.",
          "original": "There was blood on his lips."
        }
      ]
    },
    {
      "id": "para-009",
      "sentences": [
        {
          "id": "sent-022",
          "text": "Doctorul a venit repede.",
          "translationRu": "Доктор пришёл быстро.",
          "original": "The doctor came quickly."
        },
        {
          "id": "sent-023",
          "text": "Doctorul spune: este o boală.",
          "translationRu": "Доктор говорит: это болезнь.",
          "original": "The doctor says: it is an illness."
        },
        {
          "id": "sent-024",
          "text": "Spune că sângerează pe dinăuntru.",
          "translationRu": "Говорит, что кровотечение внутри.",
          "original": "He says there is bleeding inside."
        }
      ]
    },
    {
      "id": "para-010",
      "sentences": [
        {
          "id": "sent-025",
          "text": "Poirot ascultă cu atenție.",
          "translationRu": "Пуаро слушает внимательно.",
          "original": "Poirot listens carefully."
        },
        {
          "id": "sent-026",
          "text": "El se uită la grădină și gândește mult.",
          "translationRu": "Он смотрит на сад и много думает.",
          "original": "He looks at the garden and thinks a lot."
        },
        {
          "id": "sent-027",
          "text": "Apoi întreabă: cine a fost aici înainte?",
          "translationRu": "Потом спрашивает: кто был здесь раньше?",
          "original": "Then he asks: who was here before?"
        }
      ]
    },
    {
      "id": "para-011",
      "sentences": [
        {
          "id": "sent-028",
          "text": "Doamna spune: a fost un domn.",
          "translationRu": "Госпожа говорит: был один господин.",
          "original": "The lady says: a gentleman was here."
        },
        {
          "id": "sent-029",
          "text": "Numele lui este căpitanul Black.",
          "translationRu": "Его зовут капитан Блэк.",
          "original": "His name is Captain Black."
        },
        {
          "id": "sent-030",
          "text": "El este soldat.",
          "translationRu": "Он солдат.",
          "original": "He is a soldier."
        },
        {
          "id": "sent-031",
          "text": "El a venit din Africa.",
          "translationRu": "Он приехал из Африки.",
          "original": "He came from Africa."
        }
      ]
    },
    {
      "id": "para-012",
      "sentences": [
        {
          "id": "sent-032",
          "text": "Căpitanul a stat aici o seară.",
          "translationRu": "Капитан пробыл здесь один вечер.",
          "original": "The captain stayed here one evening."
        },
        {
          "id": "sent-033",
          "text": "A fost aici înainte de moarte.",
          "translationRu": "Он был здесь перед смертью.",
          "original": "He was here before the death."
        }
      ]
    },
    {
      "id": "para-013",
      "sentences": [
        {
          "id": "sent-034",
          "text": "Poirot merge să vorbească cu el.",
          "translationRu": "Пуаро идёт поговорить с ним.",
          "original": "Poirot goes to talk to him."
        },
        {
          "id": "sent-035",
          "text": "Căpitanul Black povestește o seară.",
          "translationRu": "Капитан Блэк рассказывает про тот вечер.",
          "original": "Captain Black tells about the evening."
        }
      ]
    },
    {
      "id": "para-014",
      "sentences": [
        {
          "id": "sent-036",
          "text": "El spune: am spus o poveste la cină.",
          "translationRu": "Он говорит: за ужином я рассказал историю.",
          "original": "He says: I told a story at dinner."
        },
        {
          "id": "sent-037",
          "text": "Un om și-a pus pușca în gură.",
          "translationRu": "Один человек вставил ружьё в рот.",
          "original": "A man put a gun in his mouth."
        },
        {
          "id": "sent-038",
          "text": "Afară nu se vedea nimic.",
          "translationRu": "Снаружи ничего не было видно.",
          "original": "Nothing could be seen outside."
        },
        {
          "id": "sent-039",
          "text": "Doar puțin sânge pe buze.",
          "translationRu": "Только немного крови на губах.",
          "original": "Only a little blood on the lips."
        }
      ]
    },
    {
      "id": "para-015",
      "sentences": [
        {
          "id": "sent-040",
          "text": "Poirot ascultă și tace.",
          "translationRu": "Пуаро слушает и молчит.",
          "original": "Poirot listens and is silent."
        },
        {
          "id": "sent-041",
          "text": "Acum el înțelege ceva.",
          "translationRu": "Теперь он что-то понимает.",
          "original": "Now he understands something."
        }
      ]
    },
    {
      "id": "para-016",
      "sentences": [
        {
          "id": "sent-042",
          "text": "Poirot spune: doctorul greșește.",
          "translationRu": "Пуаро говорит: доктор ошибается.",
          "original": "Poirot says: the doctor is wrong."
        },
        {
          "id": "sent-043",
          "text": "Nu a fost o boală, a fost un glonț.",
          "translationRu": "Это была не болезнь, а пуля.",
          "original": "It was not an illness, it was a bullet."
        },
        {
          "id": "sent-044",
          "text": "Glonțul a intrat prin gură.",
          "translationRu": "Пуля вошла через рот.",
          "original": "The bullet went in through the mouth."
        },
        {
          "id": "sent-045",
          "text": "De aceea nimeni nu a văzut rana.",
          "translationRu": "Поэтому никто не увидел раны.",
          "original": "That is why no one saw the wound."
        }
      ]
    },
    {
      "id": "para-017",
      "sentences": [
        {
          "id": "sent-046",
          "text": "Cine a făcut asta?",
          "translationRu": "Кто это сделал?",
          "original": "Who did this?"
        },
        {
          "id": "sent-047",
          "text": "Poirot se gândește la soție.",
          "translationRu": "Пуаро думает о жене.",
          "original": "Poirot thinks about the wife."
        },
        {
          "id": "sent-048",
          "text": "Ea voia banii de la asigurare.",
          "translationRu": "Она хотела деньги от страховки.",
          "original": "She wanted the insurance money."
        }
      ]
    },
    {
      "id": "para-018",
      "sentences": [
        {
          "id": "sent-049",
          "text": "Soția a auzit povestea căpitanului.",
          "translationRu": "Жена услышала историю капитана.",
          "original": "The wife heard the captain's story."
        },
        {
          "id": "sent-050",
          "text": "Ea a rugat soțul să arate cum se face.",
          "translationRu": "Она попросила мужа показать, как это делается.",
          "original": "She asked her husband to show how it is done."
        },
        {
          "id": "sent-051",
          "text": "Soțul a pus pușca în gură.",
          "translationRu": "Муж вставил ружьё в рот.",
          "original": "The husband put the gun in his mouth."
        },
        {
          "id": "sent-052",
          "text": "Apoi ea a apăsat pe trăgaci.",
          "translationRu": "Потом она нажала на курок.",
          "original": "Then she pulled the trigger."
        }
      ]
    },
    {
      "id": "para-019",
      "sentences": [
        {
          "id": "sent-053",
          "text": "Dar Poirot nu are dovadă.",
          "translationRu": "Но у Пуаро нет доказательства.",
          "original": "But Poirot has no proof."
        },
        {
          "id": "sent-054",
          "text": "El are nevoie de o mărturisire.",
          "translationRu": "Ему нужно признание.",
          "original": "He needs a confession."
        },
        {
          "id": "sent-055",
          "text": "Așa că face un plan.",
          "translationRu": "Поэтому он придумывает план.",
          "original": "So he makes a plan."
        }
      ]
    },
    {
      "id": "para-020",
      "sentences": [
        {
          "id": "sent-056",
          "text": "Poirot cheamă un actor.",
          "translationRu": "Пуаро зовёт актёра.",
          "original": "Poirot calls an actor."
        },
        {
          "id": "sent-057",
          "text": "Seara, în casă este întuneric.",
          "translationRu": "Вечером в доме темно.",
          "original": "In the evening the house is dark."
        },
        {
          "id": "sent-058",
          "text": "Deodată apare o figură albă.",
          "translationRu": "Вдруг появляется белая фигура.",
          "original": "Suddenly a white figure appears."
        },
        {
          "id": "sent-059",
          "text": "Pare a fi soțul mort.",
          "translationRu": "Она похожа на мёртвого мужа.",
          "original": "It looks like the dead husband."
        }
      ]
    },
    {
      "id": "para-021",
      "sentences": [
        {
          "id": "sent-060",
          "text": "Doamna Maltravers se sperie tare.",
          "translationRu": "Госпожа Малтраверс сильно пугается.",
          "original": "Mrs. Maltravers is very frightened."
        },
        {
          "id": "sent-061",
          "text": "Ea crede că vede o stafie.",
          "translationRu": "Она думает, что видит призрака.",
          "original": "She thinks she sees a ghost."
        },
        {
          "id": "sent-062",
          "text": "Ea strigă și spune adevărul.",
          "translationRu": "Она кричит и говорит правду.",
          "original": "She cries out and tells the truth."
        },
        {
          "id": "sent-063",
          "text": "Ea spune: eu am făcut-o!",
          "translationRu": "Она говорит: это сделала я!",
          "original": "She says: I did it!"
        }
      ]
    },
    {
      "id": "para-022",
      "sentences": [
        {
          "id": "sent-064",
          "text": "Acum totul este clar.",
          "translationRu": "Теперь всё ясно.",
          "original": "Now everything is clear."
        },
        {
          "id": "sent-065",
          "text": "Soția a omorât soțul ei pentru bani.",
          "translationRu": "Жена убила мужа ради денег.",
          "original": "The wife killed her husband for money."
        },
        {
          "id": "sent-066",
          "text": "Compania nu va plăti.",
          "translationRu": "Компания не будет платить.",
          "original": "The company will not pay."
        }
      ]
    },
    {
      "id": "para-023",
      "sentences": [
        {
          "id": "sent-067",
          "text": "Poirot zâmbește puțin.",
          "translationRu": "Пуаро немного улыбается.",
          "original": "Poirot smiles a little."
        },
        {
          "id": "sent-068",
          "text": "Micii lui neuroni cenușii au lucrat din nou.",
          "translationRu": "Его маленькие серые клеточки снова поработали.",
          "original": "His little grey cells worked again."
        }
      ]
    }
  ]
}
