{
  "schemaVersion": "1.0",
  "workId": "the-circular-staircase",
  "level": "a2",
  "chapter": {
    "id": "chapter-004",
    "number": 4,
    "title": "Halsey ha desaparecido"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Una noche, Halsey salió en el coche.",
          "translationRu": "Ночью Халси уехал на машине."
        },
        {
          "id": "sent-002",
          "text": "Fue a ver al doctor Walker.",
          "translationRu": "Он пошел увидеть доктора Уокера."
        },
        {
          "id": "sent-003",
          "text": "El doctor quería casarse con Louise.",
          "translationRu": "Доктор хотел жениться на Луизе."
        },
        {
          "id": "sent-004",
          "text": "Pero Halsey también amaba a Louise.",
          "translationRu": "Но Халси тоже любил Луизу."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-005",
          "text": "El coche de Halsey chocó con un tren.",
          "translationRu": "Машина Халси столкнулась с поездом."
        },
        {
          "id": "sent-006",
          "text": "Encontramos el coche destrozado.",
          "translationRu": "Мы нашли разбитую машину."
        },
        {
          "id": "sent-007",
          "text": "Pero Halsey no estaba allí.",
          "translationRu": "Но Халси там не было."
        },
        {
          "id": "sent-008",
          "text": "Desapareció.",
          "translationRu": "Он исчез."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-009",
          "text": "Louise estaba muy asustada.",
          "translationRu": "Луиза была очень напугана."
        },
        {
          "id": "sent-010",
          "text": "Vino a la casa buscando a Halsey.",
          "translationRu": "Она пришла в дом в поиске Халси."
        },
        {
          "id": "sent-011",
          "text": "Dijo que sabía que algo malo iba a pasar.",
          "translationRu": "Она сказала, что знала, что произойдет что-то плохое."
        },
        {
          "id": "sent-012",
          "text": "Pero no quiso decirnos qué era.",
          "translationRu": "Но она не хотела нам говорить что это было."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Pasaron días sin noticias de Halsey.",
          "translationRu": "Прошли дни без новостей о Халси."
        },
        {
          "id": "sent-014",
          "text": "Estábamos muy preocupados.",
          "translationRu": "Мы были очень обеспокоены."
        },
        {
          "id": "sent-015",
          "text": "Finalmente, un mendigo nos trajo una nota.",
          "translationRu": "Наконец, бродяга принес нам записку."
        },
        {
          "id": "sent-016",
          "text": "Halsey estaba en un hospital lejos de aquí.",
          "translationRu": "Халси был в больнице далеко отсюда."
        }
      ]
    }
  ]
}
