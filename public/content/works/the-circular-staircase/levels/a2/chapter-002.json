{
  "schemaVersion": "1.0",
  "workId": "the-circular-staircase",
  "level": "a2",
  "chapter": {
    "id": "chapter-002",
    "number": 2,
    "title": "Un crimen en la noche"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "A las tres de la mañana, escuchamos un disparo.",
          "translationRu": "В три часа ночи мы услышали выстрел."
        },
        {
          "id": "sent-002",
          "text": "Gertrude gritó con miedo.",
          "translationRu": "Гертруда крикнула от страха."
        },
        {
          "id": "sent-003",
          "text": "Bajamos las escaleras rápidamente.",
          "translationRu": "Мы быстро спустились по лестнице."
        },
        {
          "id": "sent-004",
          "text": "En el salón encontramos a un hombre muerto.",
          "translationRu": "В гостиной мы нашли мертвого человека."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-005",
          "text": "El hombre se llamaba Arnold Armstrong.",
          "translationRu": "Человека звали Арнольд Армстронг."
        },
        {
          "id": "sent-006",
          "text": "Era el hijo del presidente del banco de la ciudad.",
          "translationRu": "Он был сыном президента городского банка."
        },
        {
          "id": "sent-007",
          "text": "Había sido disparado en el pecho.",
          "translationRu": "Его ранили в грудь."
        },
        {
          "id": "sent-008",
          "text": "Estaba muerto.",
          "translationRu": "Он был мертв."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-009",
          "text": "¿Dónde estaban Halsey y Bailey?",
          "translationRu": "Где были Халси и Бейли?"
        },
        {
          "id": "sent-010",
          "text": "Sus cuartos estaban vacíos.",
          "translationRu": "Их комнаты были пусты."
        },
        {
          "id": "sent-011",
          "text": "Habían desaparecido durante la noche.",
          "translationRu": "Они исчезли ночью."
        },
        {
          "id": "sent-012",
          "text": "No sabía por qué.",
          "translationRu": "Я не знала почему."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Un detective llegó a la casa.",
          "translationRu": "Детектив приехал в дом."
        },
        {
          "id": "sent-014",
          "text": "Su nombre era Jamieson.",
          "translationRu": "Его звали Джеймсон."
        },
        {
          "id": "sent-015",
          "text": "Preguntó muchas cosas sobre Halsey y Bailey.",
          "translationRu": "Он задал много вопросов о Халси и Бейли."
        },
        {
          "id": "sent-016",
          "text": "Parecía que sospechaba de ellos.",
          "translationRu": "Казалось, он подозревал их."
        }
      ]
    }
  ]
}
