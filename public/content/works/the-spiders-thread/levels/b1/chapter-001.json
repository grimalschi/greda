          "id": "sent-209",
          "text": "Las flores blancas como perlas",
          "translationRu": "Белые, как жемчуг, цветы",
          "original": "The pearly white flowers"
        },
        {
          "id": "sent-210",
          "text": "se mecían alrededor de los pies del Buda.",
          "translationRu": "покачивались у ног Будды.",
          "original": "were swaying about the Buddha's feet."
        },
        {
          "id": "sent-211",
          "text": "Mientras se mecían,",
          "translationRu": "Покачиваясь,",
          "original": "As they swayed,"
        },
        {
          "id": "sent-212",
          "text": "los pistilos dorados de sus centros",
          "translationRu": "золотые пестики в их центрах",
          "original": "from the golden pistils in their centers,"
        },
