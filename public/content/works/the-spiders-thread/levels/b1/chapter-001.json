{
  "schemaVersion": "1.0",
  "workId": "the-spiders-thread",
  "level": "b1",
  "chapter": {
    "id": "chapter-001",
    "number": 1,
    "title": "El hilo de la araña"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Un día",
          "translationRu": "Однажды",
          "original": "One day"
        },
        {
          "id": "sent-002",
          "text": "el Buda paseaba solo",
          "translationRu": "Будда прогуливался в одиночестве",
          "original": "the Buddha was sauntering alone"
        },
        {
          "id": "sent-003",
          "text": "por la orilla del estanque de lotos",
          "translationRu": "по берегу лотосового пруда",
          "original": "on the brink of the lotus pond"
        },
        {
          "id": "sent-004",
          "text": "del Paraíso.",
          "translationRu": "в Раю.",
          "original": "of Paradise."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-005",
          "text": "Las flores de loto",
          "translationRu": "Цветы лотоса,",
          "original": "The lotus flowers"
        },
        {
          "id": "sent-006",
          "text": "que florecían en el estanque",
          "translationRu": "цветущие в пруду,",
          "original": "in bloom in the pond"
        },
        {
          "id": "sent-007",
          "text": "eran todas tan blancas como las perlas.",
          "translationRu": "были все белы, как жемчуг.",
          "original": "were all as white as pearls"
        },
        {
          "id": "sent-008",
          "text": "En el centro de cada flor",
          "translationRu": "В центре каждого цветка",
          "original": "and"
        },
        {
          "id": "sent-009",
          "text": "había pistilos y estambres dorados",
          "translationRu": "были золотые пестики и тычинки,",
          "original": "the golden pistils and stamens in their centers"
        },
        {
          "id": "sent-010",
          "text": "que llenaban sin cesar el aire",
          "translationRu": "которые беспрерывно наполняли воздух",
          "original": "ceaselessly filled all the air"
        },
        {
          "id": "sent-011",
          "text": "con una fragancia indescriptible.",
          "translationRu": "невыразимым ароматом.",
          "original": "with ineffable fragrance."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Era la mañana",
          "translationRu": "Было утро",
          "original": "It was morning"
        },
        {
          "id": "sent-013",
          "text": "en el Paraíso.",
          "translationRu": "в Раю.",
          "original": "in Paradise."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-014",
          "text": "En ese momento",
          "translationRu": "В этот момент",
          "original": "Presently"
        },
        {
          "id": "sent-015",
          "text": "el Buda se detuvo",
          "translationRu": "Будда остановился",
          "original": "the Buddha stood still"
        },
        {
          "id": "sent-016",
          "text": "en la orilla del estanque.",
          "translationRu": "на берегу пруда.",
          "original": "on the brink of the pond"
        },
        {
          "id": "sent-017",
          "text": "Miró a través de un hueco",
          "translationRu": "Он посмотрел сквозь просвет",
          "original": "and through an opening"
        },
        {
          "id": "sent-018",
          "text": "entre las hojas",
          "translationRu": "между листьями,",
          "original": "among the leaves"
        },
        {
          "id": "sent-019",
          "text": "que cubrían la superficie del agua.",
          "translationRu": "покрывавшими поверхность воды.",
          "original": "which covered the face of the water"
        },
        {
          "id": "sent-020",
          "text": "De repente vio",
          "translationRu": "Вдруг он увидел",
          "original": "suddenly beheld"
        },
        {
          "id": "sent-021",
          "text": "la escena que había abajo.",
          "translationRu": "картину, которая была внизу.",
          "original": "the scene below."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-022",
          "text": "El suelo del Infierno",
          "translationRu": "Дно Ада",
          "original": "As the floor of Hell"
        },
        {
          "id": "sent-023",
          "text": "estaba directamente debajo",
          "translationRu": "находилось прямо под",
          "original": "lay directly beneath"
        },
        {
          "id": "sent-024",
          "text": "del estanque de lotos del Paraíso.",
          "translationRu": "лотосовым прудом Рая.",
          "original": "the lotus pond of Paradise"
        },
        {
          "id": "sent-025",
          "text": "A través del agua cristalina,",
          "translationRu": "Сквозь кристальную воду"
        },
        {
          "id": "sent-026",
          "text": "el Sanzu-no-Kawa y el Hari-no-Yama",
          "translationRu": "Санзу-но-Кава и Хари-но-Яма",
          "original": "the Sanzu-no-Kawa and Hari-no-Yama"
        },
        {
          "id": "sent-027",
          "text": "eran claramente visibles,",
          "translationRu": "были отчётливо видны,",
          "original": "were distinctly visible through the crystal water,"
        },
        {
          "id": "sent-028",
          "text": "como si se miraran a través de un estereoscopio.",
          "translationRu": "словно в стереоскопе.",
          "original": "as through a sterioptiscope."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-029",
          "text": "Entonces el Buda vio",
          "translationRu": "Тогда Будда увидел",
          "original": "Then his eye fell on"
        },
        {
          "id": "sent-030",
          "text": "a un hombre llamado Kandata.",
          "translationRu": "человека по имени Кандата.",
          "original": "a man named Kandata"
        },
        {
          "id": "sent-031",
          "text": "Kandata se retorcía",
          "translationRu": "Кандата извивался",
          "original": "who was squirming"
        },
        {
          "id": "sent-032",
          "text": "junto con los otros pecadores",
          "translationRu": "вместе с другими грешниками",
          "original": "with the other sinners"
        },
        {
          "id": "sent-033",
          "text": "en el fondo del Infierno.",
          "translationRu": "на дне Ада.",
          "original": "in the bottom of Hell."
        }
      ]
    },
    {
      "id": "para-007",
      "sentences": [
        {
          "id": "sent-034",
          "text": "Este Kandata era un gran ladrón",
          "translationRu": "Этот Кандата был великим разбойником,",
          "original": "This Kandata was a great robber"
        },
        {
          "id": "sent-035",
          "text": "que había hecho muchas cosas malas.",
          "translationRu": "совершившим много злодеяний.",
          "original": "who had done many evil things"
        },
        {
          "id": "sent-036",
          "text": "Había matado a personas",
          "translationRu": "Он убивал людей",
          "original": "murdering"
        },
        {
          "id": "sent-037",
          "text": "y quemado casas.",
          "translationRu": "и поджигал дома.",
          "original": "and setting fire to houses"
        },
        {
          "id": "sent-038",
          "text": "Pero había hecho una buena acción en su vida.",
          "translationRu": "Но в его жизни был один добрый поступок.",
          "original": "but he had to his credit one good action."
        },
        {
          "id": "sent-039",
          "text": "Una vez,",
          "translationRu": "Однажды,",
          "original": "Once"
        },
        {
          "id": "sent-040",
          "text": "mientras caminaba por un bosque profundo,",
          "translationRu": "проходя через густой лес,",
          "original": "while on his way through a deep forest,"
        },
        {
          "id": "sent-041",
          "text": "vio una pequeña araña",
          "translationRu": "он заметил маленького паука,",
          "original": "he had noticed a little spider"
        },
        {
          "id": "sent-042",
          "text": "que se arrastraba por el camino.",
          "translationRu": "ползущего по дороге.",
          "original": "creeping along beside the road."
        }
      ]
    },
    {
      "id": "para-008",
      "sentences": [
        {
          "id": "sent-043",
          "text": "Levantó el pie rápidamente",
          "translationRu": "Он быстро поднял ногу",
          "original": "So quickly lifting his foot,"
        },
        {
          "id": "sent-044",
          "text": "y estaba a punto de aplastarlo.",
          "translationRu": "и уже готов был раздавить паука.",
          "original": "he was about to trample it to death"
        },
        {
          "id": "sent-045",
          "text": "Pero de repente pensó:",
          "translationRu": "Но вдруг подумал:",
          "original": "when he suddenly thought,"
        },
        {
          "id": "sent-046",
          "text": "«No, no,",
          "translationRu": "«Нет, нет,",
          "original": "\"No, no,"
        },
        {
          "id": "sent-047",
          "text": "aunque esta criatura es tan pequeña,",
          "translationRu": "хоть это существо и мало,",
          "original": "as small as this thing is,"
        },
        {
          "id": "sent-048",
          "text": "también tiene un alma».",
          "translationRu": "у него тоже есть душа».",
          "original": "it, too, has a soul:"
        },
        {
          "id": "sent-049",
          "text": "«Sería una lástima matarlo sin razón»,",
          "translationRu": "«Было бы жаль убивать его без причины», —",
          "original": "it would be rather a shame to recklessly kill it,\""
        },
        {
          "id": "sent-050",
          "text": "pensó.",
          "translationRu": "подумал он."
        },
        {
          "id": "sent-051",
          "text": "Y perdonó la vida de la araña.",
          "translationRu": "И он пощадил паука.",
          "original": "and spared the spider's life."
        }
      ]
    },
    {
      "id": "para-009",
      "sentences": [
        {
          "id": "sent-052",
          "text": "Mientras miraba hacia el Infierno,",
          "translationRu": "Глядя вниз, в Ад,",
          "original": "As he looked down into Hell,"
        },
        {
          "id": "sent-053",
          "text": "el Buda recordó",
          "translationRu": "Будда вспомнил,",
          "original": "the Buddha remembered"
        },
        {
          "id": "sent-054",
          "text": "cómo Kandata había perdonado la vida de la araña.",
          "translationRu": "как Кандата пощадил паука.",
          "original": "how this Kandata had spared the spider's life."
        },
        {
          "id": "sent-055",
          "text": "Por esa buena acción,",
          "translationRu": "За этот добрый поступок",
          "original": "And in return for that good deed,"
        },
        {
          "id": "sent-056",
          "text": "el Buda pensó que,",
          "translationRu": "Будда подумал, что,",
          "original": "he thought,"
        },
        {
          "id": "sent-057",
          "text": "si era posible,",
          "translationRu": "если возможно,",
          "original": "if possible,"
        },
        {
          "id": "sent-058",
          "text": "le gustaría salvarlo del Infierno.",
          "translationRu": "хотел бы спасти его из Ада.",
          "original": "he would like to deliver him out of Hell."
        },
        {
          "id": "sent-059",
          "text": "Por suerte,",
          "translationRu": "К счастью,",
          "original": "Fortunately"
        },
        {
          "id": "sent-060",
          "text": "cuando miró a su alrededor,",
          "translationRu": "оглядевшись,",
          "original": "when he looked around,"
        },
        {
          "id": "sent-061",
          "text": "vio una araña del Paraíso",
          "translationRu": "он увидел райского паука,",
          "original": "he saw a spider of Paradise"
        },
        {
          "id": "sent-062",
          "text": "que tejía un hermoso hilo plateado",
          "translationRu": "прядущего прекрасную серебристую нить",
          "original": "spinning a beautiful silvery thread"
        },
        {
          "id": "sent-063",
          "text": "sobre las hojas de loto de color sereno.",
          "translationRu": "на спокойно-синих листьях лотоса.",
          "original": "on the halcyon-colored lotus leaves."
        }
      ]
    },
    {
      "id": "para-010",
      "sentences": [
        {
          "id": "sent-064",
          "text": "El Buda tomó suavemente el hilo de la araña",
          "translationRu": "Будда тихо взял нить паука",
          "original": "The Buddha quietly took up the spider's thread"
        },
        {
          "id": "sent-065",
          "text": "en su mano.",
          "translationRu": "в руку.",
          "original": "in his hand."
        },
        {
          "id": "sent-066",
          "text": "Lo dejó caer recto hacia abajo,",
          "translationRu": "Он опустил её прямо вниз,",
          "original": "And he let it straight down"
        },
        {
          "id": "sent-067",
          "text": "hasta el fondo del Infierno, muy lejos,",
          "translationRu": "до самого дна Ада, далеко-далеко,",
          "original": "to the bottom of Hell far below"
        },
        {
          "id": "sent-068",
          "text": "a través del hueco",
          "translationRu": "сквозь просвет",
          "original": "through the opening"
        },
        {
          "id": "sent-069",
          "text": "entre las flores de loto blancas como perlas.",
          "translationRu": "между белыми жемчужными цветами лотоса.",
          "original": "among the pearly white lotus flowers."
        }
      ]
    },
    {
      "id": "para-011",
      "sentences": [
        {
          "id": "sent-070",
          "text": "En el Infierno,",
          "translationRu": "В Аду",
          "original": "Here"
        },
        {
          "id": "sent-071",
          "text": "Kandata subía y bajaba",
          "translationRu": "Кандата поднимался и опускался",
          "original": "Kandata was rising and sinking"
        },
        {
          "id": "sent-072",
          "text": "junto con los otros pecadores",
          "translationRu": "вместе с другими грешниками",
          "original": "with the other sinners"
        },
        {
          "id": "sent-073",
          "text": "en el Estanque de Sangre.",
          "translationRu": "в Пруду Крови.",
          "original": "in the Pond of Blood on the floor of Hell."
        }
      ]
    },
    {
      "id": "para-012",
      "sentences": [
        {
          "id": "sent-074",
          "text": "Era completamente oscuro en todas partes.",
          "translationRu": "Вокруг была кромешная тьма.",
          "original": "It was pitch black everywhere"
        },
        {
          "id": "sent-075",
          "text": "A veces se veía algo",
          "translationRu": "Иногда в темноте что-то",
          "original": "and when sometimes a glimpse was caught of something rising from that darkness, it turned out to be the gleam of the needle of the dread Hari-no-Yama"
        },
        {
          "id": "sent-076",
          "text": "que brillaba en la oscuridad.",
          "translationRu": "поблёскивало."
        },
        {
          "id": "sent-077",
          "text": "Era el destello de las agujas",
          "translationRu": "Это был блеск игл",
          "original": "it turned out to be the gleam of the needle"
        },
        {
          "id": "sent-078",
          "text": "del temible Hari-no-Yama.",
          "translationRu": "страшного Хари-но-Яма.",
          "original": "of the dread Hari-no-Yama"
        },
        {
          "id": "sent-079",
          "text": "Todo eso hacía aquel lugar terriblemente sombrío.",
          "translationRu": "Всё это делало это место ужасно мрачным.",
          "original": "so it was inexpressibly forbidding."
        },
        {
          "id": "sent-080",
          "text": "Además,",
          "translationRu": "К тому же",
          "original": "Moreover"
        },
        {
          "id": "sent-081",
          "text": "reinaba el silencio de la tumba.",
          "translationRu": "царила гробовая тишина.",
          "original": "the stillness of the grave reigned everywhere"
        },
        {
          "id": "sent-082",
          "text": "Solo a veces se escuchaba",
          "translationRu": "Лишь иногда слышался",
          "original": "and the only thing that could at times be heard was"
        },
        {
          "id": "sent-083",
          "text": "el débil suspiro de los pecadores.",
          "translationRu": "слабый вздох грешников.",
          "original": "the faint sighing of the sinners."
        }
      ]
    },
    {
      "id": "para-013",
      "sentences": [
        {
          "id": "sent-084",
          "text": "Los pecadores",
          "translationRu": "Грешники,",
          "original": "This was because such sinners"
        },
        {
          "id": "sent-085",
          "text": "que habían llegado a ese lugar",
          "translationRu": "оказавшиеся в этом месте,",
          "original": "as had come down to this spot"
        },
        {
          "id": "sent-086",
          "text": "ya estaban agotados",
          "translationRu": "уже были измотаны",
          "original": "had already been tired out"
        },
        {
          "id": "sent-087",
          "text": "por los muchos tormentos del Infierno.",
          "translationRu": "многочисленными муками Ада.",
          "original": "by the other manifold tortures of Hell"
        },
        {
          "id": "sent-088",
          "text": "Habían perdido incluso la fuerza",
          "translationRu": "Они потеряли даже силы",
          "original": "and had lost even the strength"
        },
        {
          "id": "sent-089",
          "text": "para gritar.",
          "translationRu": "кричать.",
          "original": "to cry aloud."
        }
      ]
    },
    {
      "id": "para-014",
      "sentences": [
        {
          "id": "sent-090",
          "text": "Así que Kandata,",
          "translationRu": "Так что Кандата,",
          "original": "So,"
        },
        {
          "id": "sent-091",
          "text": "aunque era un gran ladrón,",
          "translationRu": "хотя и был великим разбойником,",
          "original": "great robber though he was, Kandata,"
        },
        {
          "id": "sent-092",
          "text": "también estaba sofocado por la sangre.",
          "translationRu": "тоже задыхался в крови.",
          "original": "also suffocated with the blood"
        },
        {
          "id": "sent-093",
          "text": "No podía hacer nada,",
          "translationRu": "Он не мог ничего поделать,",
          "original": "could do nothing but"
        },
        {
          "id": "sent-094",
          "text": "solo retorcerse en el estanque",
          "translationRu": "только барахтаться в пруду,",
          "original": "struggle in the pond"
        },
        {
          "id": "sent-095",
          "text": "como una rana que se muere.",
          "translationRu": "как умирающая лягушка.",
          "original": "like a dying frog."
        }
      ]
    },
    {
      "id": "para-015",
      "sentences": [
        {
          "id": "sent-096",
          "text": "Pero llegó su momento.",
          "translationRu": "Но его час настал.",
          "original": "But his time came."
        },
        {
          "id": "sent-097",
          "text": "Un día",
          "translationRu": "Однажды",
          "original": "One day when"
        },
        {
          "id": "sent-098",
          "text": "Kandata levantó la cabeza por casualidad",
          "translationRu": "Кандата случайно поднял голову",
          "original": "Kandata lifted his head by chance"
        },
        {
          "id": "sent-099",
          "text": "y miró hacia arriba,",
          "translationRu": "и взглянул вверх,",
          "original": "and looked up"
        },
        {
          "id": "sent-100",
          "text": "al cielo sobre el Estanque de Sangre.",
          "translationRu": "на небо над Прудом Крови.",
          "original": "at the sky above the Pond of Blood"
        },
        {
          "id": "sent-101",
          "text": "Vio un hilo plateado de araña",
          "translationRu": "Он увидел серебристую паучью нить,",
          "original": "he saw a silver spider's thread"
        },
        {
          "id": "sent-102",
          "text": "que bajaba hacia él",
          "translationRu": "которая спускалась к нему",
          "original": "slipping down toward him"
        },
        {
          "id": "sent-103",
          "text": "desde lo alto, muy alto, del cielo.",
          "translationRu": "с высоты, очень высокой высоты, с неба.",
          "original": "from the high, high heavens"
        },
        {
          "id": "sent-104",
          "text": "El hilo brillaba levemente",
          "translationRu": "Нить слабо мерцала",
          "original": "glittering slightly"
        },
        {
          "id": "sent-105",
          "text": "en la oscuridad silenciosa,",
          "translationRu": "в тихой темноте,",
          "original": "in the silent darkness"
        },
        {
          "id": "sent-106",
          "text": "como si tuviera miedo de los ojos de los hombres.",
          "translationRu": "словно боялась человеческих глаз.",
          "original": "just as if it feared the eyes of man."
        }
      ]
    },
    {
      "id": "para-016",
      "sentences": [
        {
          "id": "sent-107",
          "text": "Cuando lo vio,",
          "translationRu": "Увидев это,",
          "original": "When he saw this,"
        },
        {
          "id": "sent-108",
          "text": "sus manos se juntaron solas de alegría.",
          "translationRu": "его руки сами собой сложились от радости.",
          "original": "his hands clapped themselves for joy."
        },
        {
