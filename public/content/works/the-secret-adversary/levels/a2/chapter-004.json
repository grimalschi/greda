  "schemaVersion": "1.0",
  "workId": "the-secret-adversary",
  "level": "a2",
  "chapter": {
    "id": "chapter-004",
    "number": 4,
    "title": "La casa peligrosa"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Tommy sigue a Whittington y un hombre ruso.",
          "translationRu": "Томми следует за Уиттингтоном и русским мужчиной."
        },
        {
          "id": "sent-002",
          "text": "Llegan a una casa sucia en Soho.",
          "translationRu": "Они прибывают в грязный дом в Сохо."
        },
        {
          "id": "sent-003",
          "text": "Hay un piquete en la puerta.",
          "translationRu": "На двери есть пост охраны."
        },
        {
          "id": "sent-004",
          "text": "Tommy dice una contraseña.",
          "translationRu": "Томми произносит пароль."
        },
        {
          "id": "sent-005",
          "text": "Entra en la casa.",
          "translationRu": "Он входит в дом."
        },
        {
          "id": "sent-006",
          "text": "Escucha una reunión secreta en una habitación.",
          "translationRu": "Он слышит тайное совещание в комнате."
        },
        {
          "id": "sent-007",
          "text": "Hay hombres criminales con números.",
          "translationRu": "Есть преступники с номерами."
        },
        {
          "id": "sent-008",
          "text": "Un hombre pequeño y pálido entra.",
          "translationRu": "Входит маленький, бледный мужчина."
        },
        {
          "id": "sent-009",
          "text": "Todos se ponen de pie para saludarlo.",
          "translationRu": "Все встают, чтобы его приветствовать."
        },
        {
          "id": "sent-010",
          "text": "Es el número uno, el jefe secreto.",
          "translationRu": "Это номер один, тайный босс."
        },
        {
          "id": "sent-011",
          "text": "Tommy está asustado.",
          "translationRu": "Томми испуган."
        },
        {
          "id": "sent-012",
          "text": "De repente, alguien lo golpea en la cabeza.",
          "translationRu": "Внезапно кто-то ударяет его по голове."
        },
        {
          "id": "sent-013",
          "text": "Todo se vuelve negro.",
          "translationRu": "Всё становится чёрным."
        },
        {
          "id": "sent-014",
          "text": "Despierta en una pequeña habitación.",
          "translationRu": "Он просыпается в маленькой комнате."
        },
        {
          "id": "sent-015",
          "text": "La puerta está cerrada.",
          "translationRu": "Дверь закрыта."
        },
        {
          "id": "sent-016",
          "text": "Está atrapado y solo.",
          "translationRu": "Он в ловушке и один."
        }
      ]
    }
  ]
}
