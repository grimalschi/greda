{
  "schemaVersion": "1.0",
  "workId": "the-secret-adversary",
  "level": "a2",
  "chapter": {
    "id": "chapter-002",
    "number": 2,
    "title": "Los jóvenes aventureros"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Tommy y Tuppence son dos amigos jóvenes.",
          "translationRu": "Томми и Таппенс — два молодых друга."
        },
        {
          "id": "sent-002",
          "text": "Se encuentran en la estación de Dover.",
          "translationRu": "Они встречаются на станции Довера."
        },
        {
          "id": "sent-003",
          "text": "Hace mucho tiempo que no se ven.",
          "translationRu": "Они давно не виделись."
        },
        {
          "id": "sent-004",
          "text": "Tommy se siente muy triste.",
          "translationRu": "Томми чувствует себя очень грустно."
        },
        {
          "id": "sent-005",
          "text": "No tiene dinero.",
          "translationRu": "У него нет денег."
        },
        {
          "id": "sent-006",
          "text": "Tuppence también es pobre.",
          "translationRu": "Таппенс тоже бедна."
        },
        {
          "id": "sent-007",
          "text": "Los dos han perdido sus trabajos.",
          "translationRu": "Оба потеряли свои работы."
        },
        {
          "id": "sent-008",
          "text": "Van a una cafetería.",
          "translationRu": "Они идут в кафе."
        },
        {
          "id": "sent-009",
          "text": "Hablan sobre su vida difícil.",
          "translationRu": "Они говорят о своей трудной жизни."
        },
        {
          "id": "sent-010",
          "text": "Tuppence tiene una idea.",
          "translationRu": "У Таппенс появляется идея."
        },
        {
          "id": "sent-011",
          "text": "«Vamos a ser aventureros», dice.",
          "translationRu": "«Давайте будем искателями приключений», — говорит она."
        },
        {
          "id": "sent-012",
          "text": "«Vamos a poner un anuncio».",
          "translationRu": "«Давайте разместим объявление»."
        },
        {
          "id": "sent-013",
          "text": "El anuncio dice: «Dos jóvenes aventureros buscan trabajo».",
          "translationRu": "Объявление гласит: «Два молодых искателя приключений ищут работу»."
        },
        {
          "id": "sent-014",
          "text": "Tommy piensa que es una idea loca.",
          "translationRu": "Томми думает, что это сумасшедшая идея."
        },
        {
          "id": "sent-015",
          "text": "Pero también piensa que puede funcionar.",
          "translationRu": "Но он также думает, что это может сработать."
        },
        {
          "id": "sent-016",
          "text": "Los dos brindan por su nuevo negocio.",
          "translationRu": "Они оба поднимают тост за своё новое предприятие."
        }
      ]
    }
  ]
}
