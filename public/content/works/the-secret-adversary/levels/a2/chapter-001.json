{
  "schemaVersion": "1.0",
  "workId": "the-secret-adversary",
  "level": "a2",
  "chapter": {
    "id": "chapter-001",
    "number": 1,
    "title": "El naufragio del Lusitania"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "El barco Lusitania se hunde en el océano Atlántico.",
          "translationRu": "Корабль «Люзитания» тонет в Атлантическом океане."
        },
        {
          "id": "sent-002",
          "text": "Es el 7 de mayo de 1915.",
          "translationRu": "Это 7 мая 1915 года."
        },
        {
          "id": "sent-003",
          "text": "Los botes salvavidas están listos.",
          "translationRu": "Спасательные лодки готовы."
        },
        {
          "id": "sent-004",
          "text": "Las mujeres y los niños esperan su turno.",
          "translationRu": "Женщины и дети ждут своей очереди."
        },
        {
          "id": "sent-005",
          "text": "Una joven está de pie, sola y tranquila.",
          "translationRu": "Молодая девушка стоит одна и спокойна."
        },
        {
          "id": "sent-006",
          "text": "Tiene solo dieciocho años.",
          "translationRu": "Ей всего восемнадцать лет."
        },
        {
          "id": "sent-007",
          "text": "Un hombre se acerca a ella.",
          "translationRu": "Мужчина приближается к ней."
        },
        {
          "id": "sent-008",
          "text": "El hombre tiene miedo.",
          "translationRu": "Мужчина испуган."
        },
        {
          "id": "sent-009",
          "text": "Él lleva papeles muy importantes.",
          "translationRu": "Он несёт очень важные документы."
        },
        {
          "id": "sent-010",
          "text": "Los papeles pueden salvar a los Aliados.",
          "translationRu": "Документы могут спасти Союзников."
        },
        {
          "id": "sent-011",
          "text": "Le pregunta a la joven si es una patriota americana.",
          "translationRu": "Он спрашивает девушку, является ли она патриоткой Америки."
        },
        {
          "id": "sent-012",
          "text": "«Lleva estos papeles», le dice el hombre.",
          "translationRu": "«Возьми эти документы», — говорит ей мужчина."
        },
        {
          "id": "sent-013",
          "text": "La joven toma el paquete sin dudarlo.",
          "translationRu": "Девушка берёт пакет без колебаний."
        },
        {
          "id": "sent-014",
          "text": "El hombre desaparece entre la multitud.",
          "translationRu": "Мужчина исчезает в толпе."
        },
        {
          "id": "sent-015",
          "text": "El barco se hunde más rápido.",
          "translationRu": "Корабль тонет всё быстрее."
        },
        {
          "id": "sent-016",
          "text": "La joven entra en un bote salvavidas.",
          "translationRu": "Девушка входит в спасательную лодку."
        }
      ]
    }
  ]
}
