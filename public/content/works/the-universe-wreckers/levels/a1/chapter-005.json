  "level": "a1",
  "chapter": {
    "id": "chapter-005",
    "number": 5,
    "title": "Capítulo 5"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Caemos hacia los anillos de Saturno.",
          "translationRu": "Мы падаем к кольцам Сатурна."
        },
        {
          "id": "sent-002",
          "text": "En los anillos hay rocas grandes.",
          "translationRu": "В кольцах есть большие камни."
        },
        {
          "id": "sent-003",
          "text": "Si caemos allí, morimos.",
          "translationRu": "Если мы туда упадём, то погибнем."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Marlin tiene una idea.",
          "translationRu": "У Марлина есть идея."
        },
        {
          "id": "sent-005",
          "text": "Usamos los trajes espaciales.",
          "translationRu": "Мы используем космические скафандры."
        },
        {
          "id": "sent-006",
          "text": "Los trajes son cilindros de metal.",
          "translationRu": "Скафандры — это металлические цилиндры."
        },
        {
          "id": "sent-007",
          "text": "Salimos de la nave al espacio.",
          "translationRu": "Мы выходим из корабля в космос."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-008",
          "text": "Caemos con la nave, pero estamos bien.",
          "translationRu": "Мы падаем вместе с кораблём, но живы."
        },
        {
          "id": "sent-009",
          "text": "Reparamos los cables rotos en la nave.",
          "translationRu": "Мы ремонтируем оборванные провода на корабле."
        },
        {
          "id": "sent-010",
          "text": "Es muy difícil trabajar en el espacio.",
          "translationRu": "Работать в космосе очень трудно."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-011",
          "text": "Los anillos de Saturno están muy cerca.",
          "translationRu": "Кольца Сатурна совсем близко."
        },
        {
          "id": "sent-012",
          "text": "Trabajo muy rápido.",
          "translationRu": "Я работаю очень быстро."
        },
        {
          "id": "sent-013",
          "text": "¡Los generadores se ponen en marcha otra vez!",
          "translationRu": "Генераторы снова запускаются!"
        },
        {
          "id": "sent-014",
          "text": "Randall mueve la nave y nos alejamos de los anillos.",
          "translationRu": "Рэндалл управляет кораблём, и мы отдаляемся от колец."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-015",
          "text": "Volamos más y más lejos del sol.",
          "translationRu": "Мы летим всё дальше и дальше от солнца."
        },
        {
          "id": "sent-016",
          "text": "El sol parece muy pequeño.",
          "translationRu": "Солнце кажется очень маленьким."
        },
        {
          "id": "sent-017",
          "text": "Neptuno se ve más grande.",
          "translationRu": "Нептун становится виден крупнее."
        },
        {
          "id": "sent-018",
          "text": "Es un planeta verde y grande.",
          "translationRu": "Это большая зелёная планета."
        }
      ]
    }
  ]
}
