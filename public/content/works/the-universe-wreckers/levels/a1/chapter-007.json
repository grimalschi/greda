{
  "schemaVersion": "1.0",
  "workId": "the-universe-wreckers",
  "level": "a1",
  "chapter": {
    "id": "chapter-007",
    "number": 7,
    "title": "Capítulo 7"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Los neptunians salen de los cilindros.",
          "translationRu": "Нептуняне выходят из цилиндров."
        },
        {
          "id": "sent-002",
          "text": "Son criaturas de color verde.",
          "translationRu": "Это существа зелёного цвета."
        },
        {
          "id": "sent-003",
          "text": "Tienen un cuerpo plano y redondo.",
          "translationRu": "У них плоское круглое тело."
        },
        {
          "id": "sent-004",
          "text": "Tienen siete patas y dos ojos muy grandes.",
          "translationRu": "У них семь ног и два очень больших глаза."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-005",
          "text": "Los neptunians nos ven.",
          "translationRu": "Нептуняне замечают нас."
        },
        {
          "id": "sent-006",
          "text": "Nos atacan.",
          "translationRu": "Они нападают на нас."
        },
        {
          "id": "sent-007",
          "text": "Marlin y yo luchamos, pero hay muchos neptunians.",
          "translationRu": "Марлин и я сражаемся, но нептунян слишком много."
        },
        {
          "id": "sent-008",
          "text": "Nos capturan y nos meten en un cilindro.",
          "translationRu": "Они захватывают нас и помещают в цилиндр."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-009",
          "text": "Los neptunians llevan piezas de nuestra nave espacial.",
          "translationRu": "Нептуняне приносят обломки нашего корабля."
        },
        {
          "id": "sent-010",
          "text": "Whitely y Randall están muertos.",
          "translationRu": "Уайтли и Рэндалл погибли."
        },
        {
          "id": "sent-011",
          "text": "Los neptunians destruyeron su nave.",
          "translationRu": "Нептуняне уничтожили их корабль."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-012",
          "text": "El cilindro sale de Neptuno.",
          "translationRu": "Цилиндр покидает Нептун."
        },
        {
          "id": "sent-013",
          "text": "Vemos la luna de Neptuno.",
          "translationRu": "Мы видим луну Нептуна."
        },
        {
          "id": "sent-014",
          "text": "Se llama Tritón.",
          "translationRu": "Она называется Тритон."
        },
        {
          "id": "sent-015",
          "text": "Tritón también tiene un techo de metal.",
          "translationRu": "Тритон тоже покрыт металлической крышей."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Vemos un gran rayo de luz que sube de Tritón hacia el sol.",
          "translationRu": "Мы видим большой луч света, поднимающийся с Тритона к солнцу."
        },
        {
          "id": "sent-017",
          "text": "¡Es el rayo de fuerza gigante!",
          "translationRu": "Это гигантский луч силы!"
        },
        {
          "id": "sent-018",
          "text": "También hay un segundo rayo en la otra dirección.",
          "translationRu": "В другую сторону уходит и второй луч."
        }
      ]
    }
  ]
}
