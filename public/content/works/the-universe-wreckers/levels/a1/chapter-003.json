{
  "schemaVersion": "1.0",
  "workId": "the-universe-wreckers",
  "level": "a1",
  "chapter": {
    "id": "chapter-003",
    "number": 3,
    "title": "Capítulo 3"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "En un mes, la nave espacial está lista.",
          "translationRu": "За месяц космический корабль готов."
        },
        {
          "id": "sent-002",
          "text": "La nave tiene forma de gran bola de metal.",
          "translationRu": "Корабль имеет форму большого металлического шара."
        },
        {
          "id": "sent-003",
          "text": "Dentro hay sillas, controles y generadores.",
          "translationRu": "Внутри есть кресла, управление и генераторы."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "El mundo ayuda a construir la nave.",
          "translationRu": "Весь мир помогает строить корабль."
        },
        {
          "id": "sent-005",
          "text": "Todo el mundo tiene miedo del sol.",
          "translationRu": "Все боятся за солнце."
        },
        {
          "id": "sent-006",
          "text": "El sol gira más y más rápido cada día.",
          "translationRu": "Солнце вращается всё быстрее и быстрее каждый день."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Por la noche salimos.",
          "translationRu": "Ночью мы отправляемся."
        },
        {
          "id": "sent-008",
          "text": "Hay muchas personas en las calles.",
          "translationRu": "На улицах много людей."
        },
        {
          "id": "sent-009",
          "text": "El Presidente nos da la mano en silencio.",
          "translationRu": "Президент молча пожимает нам руки."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Entramos en la nave y cerramos la puerta.",
          "translationRu": "Мы входим в корабль и закрываем дверь."
        },
        {
          "id": "sent-011",
          "text": "Nos sentamos en las sillas.",
          "translationRu": "Мы садимся в кресла."
        },
        {
          "id": "sent-012",
          "text": "El doctor Marlin mira a Neptuno por el telescopio.",
          "translationRu": "Доктор Марлин смотрит на Нептун через телескоп."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Marlin dice: ¡Cero!",
          "translationRu": "Марлин говорит: «Ноль!»"
        },
        {
          "id": "sent-014",
          "text": "Yo abro los controles.",
          "translationRu": "Я открываю управление."
        },
        {
          "id": "sent-015",
          "text": "La nave sube muy rápido.",
          "translationRu": "Корабль взлетает очень быстро."
        },
        {
          "id": "sent-016",
          "text": "La Tierra se hace pequeña detrás de nosotros.",
          "translationRu": "Земля становится маленькой позади нас."
        },
        {
          "id": "sent-017",
          "text": "¡Volamos hacia Neptuno!",
          "translationRu": "Мы летим к Нептуну!"
        }
      ]
    }
  ]
}
