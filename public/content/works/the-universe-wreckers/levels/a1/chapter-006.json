{
  "schemaVersion": "1.0",
  "workId": "the-universe-wreckers",
  "level": "a1",
  "chapter": {
    "id": "chapter-006",
    "number": 6,
    "title": "Capítulo 6"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Llegamos a Neptuno.",
          "translationRu": "Мы прилетаем к Нептуну."
        },
        {
          "id": "sent-002",
          "text": "Entramos en la atmósfera del planeta.",
          "translationRu": "Мы входим в атмосферу планеты."
        },
        {
          "id": "sent-003",
          "text": "Vemos algo muy extraño.",
          "translationRu": "Мы видим нечто очень странное."
        },
        {
          "id": "sent-004",
          "text": "Todo Neptuno tiene un techo de metal.",
          "translationRu": "Весь Нептун покрыт металлической крышей."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-005",
          "text": "Encontramos una apertura en el techo.",
          "translationRu": "Мы находим отверстие в крыше."
        },
        {
          "id": "sent-006",
          "text": "Bajamos por la apertura.",
          "translationRu": "Мы опускаемся через отверстие."
        },
        {
          "id": "sent-007",
          "text": "Abajo hay una ciudad muy grande.",
          "translationRu": "Внизу находится очень большой город."
        },
        {
          "id": "sent-008",
          "text": "La ciudad tiene muchos muros negros.",
          "translationRu": "В городе много чёрных стен."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-009",
          "text": "No hay nadie en la ciudad.",
          "translationRu": "В городе никого нет."
        },
        {
          "id": "sent-010",
          "text": "Todo está muerto y vacío.",
          "translationRu": "Всё мёртво и пусто."
        },
        {
          "id": "sent-011",
          "text": "Hay mucho polvo sobre todo.",
          "translationRu": "На всём лежит много пыли."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Marlin y yo bajamos en trajes espaciales.",
          "translationRu": "Марлин и я спускаемся в скафандрах."
        },
        {
          "id": "sent-013",
          "text": "Whitely y Randall quedan en la nave.",
          "translationRu": "Уайтли и Рэндалл остаются в корабле."
        },
        {
          "id": "sent-014",
          "text": "Caminamos por la ciudad.",
          "translationRu": "Мы идём по городу."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-015",
          "text": "Las puertas de la ciudad son muy bajas.",
          "translationRu": "Двери в городе очень низкие."
        },
        {
          "id": "sent-016",
          "text": "Los seres de Neptuno no son como los humanos.",
          "translationRu": "Существа Нептуна непохожи на людей."
        },
        {
          "id": "sent-017",
          "text": "De repente vemos huellas en el polvo.",
          "translationRu": "Вдруг мы видим следы на пыли."
        },
        {
          "id": "sent-018",
          "text": "¡Alguien estuvo aquí recientemente!",
          "translationRu": "Кто-то был здесь совсем недавно!"
        }
      ]
    }
  ]
}
