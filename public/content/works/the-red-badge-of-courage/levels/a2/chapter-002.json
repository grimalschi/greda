{
  "schemaVersion": "1.0",
  "workId": "the-red-badge-of-courage",
  "level": "a2",
  "chapter": {
    "id": "chapter-002",
    "number": 2,
    "title": "La marcha comienza"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Por fin, el rumor era verdadero.",
          "translationRu": "Наконец слух был правдой."
        },
        {
          "id": "sent-002",
          "text": "El ejército recibió órdenes de marchar.",
          "translationRu": "Армия получила приказ маршировать."
        },
        {
          "id": "sent-003",
          "text": "Henry y sus compañeros salieron del campamento.",
          "translationRu": "Генри и его товарищи ушли из лагеря."
        },
        {
          "id": "sent-004",
          "text": "Caminaban en filas largas y polvorientas.",
          "translationRu": "Они шли длинными и пыльными рядами."
        },
        {
          "id": "sent-005",
          "text": "Los soldados estaban cansados y asustados.",
          "translationRu": "Солдаты были уставшими и напуганными."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-006",
          "text": "Henry no sabía qué esperar.",
          "translationRu": "Генри не знал, чего ожидать."
        },
        {
          "id": "sent-007",
          "text": "Miraba a su alrededor con ojos asustados.",
          "translationRu": "Он смотрел вокруг с испуганными глазами."
        },
        {
          "id": "sent-008",
          "text": "El bosque parecía oscuro y peligroso.",
          "translationRu": "Лес казался тёмным и опасным."
        },
        {
          "id": "sent-009",
          "text": "Escuchaba ruidos extraños en la distancia.",
          "translationRu": "Он слышал странные звуки вдалеке."
        },
        {
          "id": "sent-010",
          "text": "¿Eran los enemigos?",
          "translationRu": "Это были враги?"
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-011",
          "text": "Los soldados se detuvieron en un claro.",
          "translationRu": "Солдаты остановились на поляне."
        },
        {
          "id": "sent-012",
          "text": "El oficial ordenó que tomaran posiciones.",
          "translationRu": "Офицер приказал занять позиции."
        },
        {
          "id": "sent-013",
          "text": "Henry estaba muy nervioso.",
          "translationRu": "Генри был очень нервным."
        },
        {
          "id": "sent-014",
          "text": "Sostenía su rifle con manos temblorosas.",
          "translationRu": "Он держал свой винтовку дрожащими руками."
        },
        {
          "id": "sent-015",
          "text": "La batalla estaba a punto de empezar.",
          "translationRu": "Сражение вот-вот начнётся."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Jim estaba al lado de Henry.",
          "translationRu": "Джим был рядом с Генри."
        },
        {
          "id": "sent-017",
          "text": "Los dos amigos se miraron con miedo.",
          "translationRu": "Два друга посмотрели друг на друга со страхом."
        },
        {
          "id": "sent-018",
          "text": "No hablaban, solo esperaban.",
          "translationRu": "Они не говорили, просто ждали."
        }
      ]
    }
  ]
}
