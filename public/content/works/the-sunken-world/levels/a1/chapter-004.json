{
  "schemaVersion": "1.0",
  "workId": "the-sunken-world",
  "level": "a1",
  "chapter": {
    "id": "chapter-004",
    "number": 4,
    "title": "Capítulo 4"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Harkness y Rawson entran en la ciudad.",
          "translationRu": "Харкнесс и Роусон входят в город."
        },
        {
          "id": "sent-002",
          "text": "Los habitantes los atrapan.",
          "translationRu": "Жители их захватывают."
        },
        {
          "id": "sent-003",
          "text": "Los llevan a un gran salón.",
          "translationRu": "Их ведут в большой зал."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "El salón tiene paredes de zafiro y ámbar.",
          "translationRu": "Зал облицован сапфиром и янтарём."
        },
        {
          "id": "sent-005",
          "text": "Allí están los cuatro marineros perdidos.",
          "translationRu": "Там находятся четыре пропавших моряка."
        },
        {
          "id": "sent-006",
          "text": "Ellos juegan a las cartas y están bien.",
          "translationRu": "Они играют в карты и чувствуют себя хорошо."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Los atlantidenses enseñan su idioma a los marineros.",
          "translationRu": "Атлантяне учат моряков своему языку."
        },
        {
          "id": "sent-008",
          "text": "El idioma parece al griego antiguo.",
          "translationRu": "Язык похож на древнегреческий."
        },
        {
          "id": "sent-009",
          "text": "Harkness aprende rápido.",
          "translationRu": "Харкнесс учится быстро."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "La mujer hermosa se llama Aelios.",
          "translationRu": "Красивую женщину зовут Аэлиос."
        },
        {
          "id": "sent-011",
          "text": "Aelios enseña el idioma a Stranahan.",
          "translationRu": "Аэлиос учит языку Страnahана."
        },
        {
          "id": "sent-012",
          "text": "Los marineros quieren salir pero no pueden.",
          "translationRu": "Моряки хотят уйти, но не могут."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Una fuerza invisible los detiene.",
          "translationRu": "Невидимая сила их останавливает."
        },
        {
          "id": "sent-014",
          "text": "Los atlantidenses usan el poder de la mente.",
          "translationRu": "Атлантяне используют силу мысли."
        },
        {
          "id": "sent-015",
          "text": "Los marineros deben quedarse.",
          "translationRu": "Морякам приходится оставаться."
        }
      ]
    }
  ]
}
