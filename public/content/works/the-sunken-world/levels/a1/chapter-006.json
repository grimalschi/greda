{
  "schemaVersion": "1.0",
  "workId": "the-sunken-world",
  "level": "a1",
  "chapter": {
    "id": "chapter-006",
    "number": 6,
    "title": "Capítulo 6"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Aelios explica el pasado de la Atlántida.",
          "translationRu": "Аэлиос объясняет прошлое Атлантиды."
        },
        {
          "id": "sent-002",
          "text": "Antes había guerras y suciedad en la superficie.",
          "translationRu": "Раньше на поверхности были войны и грязь."
        },
        {
          "id": "sent-003",
          "text": "Agripides dijo: debemos huir bajo el agua.",
          "translationRu": "Агрипид сказал: мы должны уйти под воду."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Construyeron una cúpula de cristal.",
          "translationRu": "Они построили стеклянный купол."
        },
        {
          "id": "sent-005",
          "text": "Hundieron el continente bajo el mar.",
          "translationRu": "Континент погрузили под море."
        },
        {
          "id": "sent-006",
          "text": "Llaman esto la Buena Destrucción.",
          "translationRu": "Они называют это Добрым Разрушением."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Harkness llama al comité importante.",
          "translationRu": "Харкнесса вызывают на важный комитет."
        },
        {
          "id": "sent-008",
          "text": "El comité le da un trabajo.",
          "translationRu": "Комитет даёт ему задание."
        },
        {
          "id": "sent-009",
          "text": "Harkness es el Historiador Oficial del Mundo de Arriba.",
          "translationRu": "Харкнесс становится Официальным Историком Верхнего Мира."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Harkness viaja por toda la Atlántida.",
          "translationRu": "Харкнесс путешествует по всей Атлантиде."
        },
        {
          "id": "sent-011",
          "text": "Ve selvas, fábricas y dieciocho ciudades.",
          "translationRu": "Он видит джунгли, фабрики и восемнадцать городов."
        },
        {
          "id": "sent-012",
          "text": "Todo es limpio y tranquilo.",
          "translationRu": "Всё чисто и спокойно."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Harkness se convierte en ciudadano.",
          "translationRu": "Харкнесс становится гражданином."
        },
        {
          "id": "sent-014",
          "text": "Vive en la ciudad de Archeon.",
          "translationRu": "Он живёт в городе Археон."
        },
        {
          "id": "sent-015",
          "text": "Su vecino Xanocles quiere salir al mundo de arriba.",
          "translationRu": "Его сосед Ксаноклес хочет выйти в верхний мир."
        }
      ]
    }
  ]
}
