{
  "schemaVersion": "1.0",
  "workId": "the-sunken-world",
  "level": "a1",
  "chapter": {
    "id": "chapter-007",
    "number": 7,
    "title": "Capítulo 7"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "En el museo hay los uniformes de los marineros.",
          "translationRu": "В музее выставлена форма моряков."
        },
        {
          "id": "sent-002",
          "text": "Los atlantidenses los ven como raridades.",
          "translationRu": "Атлантяне рассматривают их как диковины."
        },
        {
          "id": "sent-003",
          "text": "Los marineros no están contentos.",
          "translationRu": "Моряки недовольны."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Hay una noticia terrible.",
          "translationRu": "Приходит ужасная новость."
        },
        {
          "id": "sent-005",
          "text": "La pared de cristal tiene una grieta.",
          "translationRu": "В стеклянной стене есть трещина."
        },
        {
          "id": "sent-006",
          "text": "La proa del X-111 rompió el cristal.",
          "translationRu": "Нос X-111 разбил стекло."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Todos van a ver la grieta.",
          "translationRu": "Все идут смотреть на трещину."
        },
        {
          "id": "sent-008",
          "text": "El agua del mar entra poco a poco.",
          "translationRu": "Морская вода медленно просачивается."
        },
        {
          "id": "sent-009",
          "text": "Los barcos pequeños intentan reparar la pared.",
          "translationRu": "Маленькие корабли пытаются починить стену."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Después de ocho días el barco Acrola repara la grieta.",
          "translationRu": "Через восемь дней корабль «Акрола» заделывает трещину."
        },
        {
          "id": "sent-011",
          "text": "Los atlantidenses celebran.",
          "translationRu": "Атлантяне празднуют."
        },
        {
          "id": "sent-012",
          "text": "Pero un ingeniero dice que la reparación no es buena.",
          "translationRu": "Но один инженер говорит, что ремонт ненадёжен."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Nadie escucha al ingeniero.",
          "translationRu": "Никто не слушает инженера."
        },
        {
          "id": "sent-014",
          "text": "La gente piensa que todo está bien.",
          "translationRu": "Люди думают, что всё в порядке."
        },
        {
          "id": "sent-015",
          "text": "La vida vuelve a la normalidad.",
          "translationRu": "Жизнь возвращается в норму."
        }
      ]
    }
  ]
}
