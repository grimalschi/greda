{
  "schemaVersion": "1.0",
  "workId": "the-sunken-world",
  "level": "a1",
  "chapter": {
    "id": "chapter-003",
    "number": 3,
    "title": "Capítulo 3"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Harkness y Rawson caminan por un camino de mármol.",
          "translationRu": "Харкнесс и Роусон идут по мраморной дорожке."
        },
        {
          "id": "sent-002",
          "text": "Hay un templo muy grande.",
          "translationRu": "Есть очень большой храм."
        },
        {
          "id": "sent-003",
          "text": "El templo parece griego.",
          "translationRu": "Храм похож на греческий."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Un barco con remeros pasa por el río.",
          "translationRu": "По реке проплывает лодка с гребцами."
        },
        {
          "id": "sent-005",
          "text": "Unas mujeres bailan cerca del templo.",
          "translationRu": "Рядом с храмом танцуют женщины."
        },
        {
          "id": "sent-006",
          "text": "Una mujer muy hermosa ve a Harkness.",
          "translationRu": "Очень красивая женщина видит Харкнесса."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Ella tiene miedo y corre.",
          "translationRu": "Она пугается и убегает."
        },
        {
          "id": "sent-008",
          "text": "Harkness ve inscripciones en las paredes.",
          "translationRu": "Харкнесс видит надписи на стенах."
        },
        {
          "id": "sent-009",
          "text": "Las letras parecen griegas.",
          "translationRu": "Буквы похожи на греческие."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Harkness lee: \"Año tres mil de la Submersión\".",
          "translationRu": "Харкнесс читает: «Год три тысячи Погружения»."
        },
        {
          "id": "sent-011",
          "text": "Desde lo alto ve toda la ciudad.",
          "translationRu": "С высоты он видит весь город."
        },
        {
          "id": "sent-012",
          "text": "La ciudad es muy grande y bella.",
          "translationRu": "Город очень большой и красивый."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Harkness comprende algo importante.",
          "translationRu": "Харкнесс понимает кое-что важное."
        },
        {
          "id": "sent-014",
          "text": "Están bajo el océano.",
          "translationRu": "Они находятся под океаном."
        },
        {
          "id": "sent-015",
          "text": "Esta ciudad es la Atlántida.",
          "translationRu": "Этот город — Атлантида."
        }
      ]
    }
  ]
}
