{
  "schemaVersion": "1.0",
  "workId": "the-sunken-world",
  "level": "a1",
  "chapter": {
    "id": "chapter-009",
    "number": 9,
    "title": "Capítulo 9"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Aelios quiere ir con Harkness.",
          "translationRu": "Аэлиос хочет ехать вместе с Харкнессом."
        },
        {
          "id": "sent-002",
          "text": "Harkness y Aelios suben al submarino.",
          "translationRu": "Харкнесс и Аэлиос поднимаются на подводную лодку."
        },
        {
          "id": "sent-003",
          "text": "Los amigos dicen adiós.",
          "translationRu": "Друзья прощаются."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "El barco sale de la Atlántida.",
          "translationRu": "Корабль покидает Атлантиду."
        },
        {
          "id": "sent-005",
          "text": "Harkness llega a Washington.",
          "translationRu": "Харкнесс прибывает в Вашингтон."
        },
        {
          "id": "sent-006",
          "text": "Nadie cree su historia.",
          "translationRu": "Никто не верит его рассказу."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Harkness tiene una barba larga y la piel verde.",
          "translationRu": "У Харкнесса длинная борода и зеленоватая кожа."
        },
        {
          "id": "sent-008",
          "text": "La gente piensa que está loco.",
          "translationRu": "Люди думают, что он сумасшедший."
        },
        {
          "id": "sent-009",
          "text": "Pero su amigo Frank lo reconoce.",
          "translationRu": "Но его друг Фрэнк его узнаёт."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Por fin la gente cree a Harkness.",
          "translationRu": "Наконец люди верят Харкнессу."
        },
        {
          "id": "sent-011",
          "text": "Un grupo de ingenieros va con él a la Atlántida.",
          "translationRu": "Группа инженеров отправляется с ним в Атлантиду."
        },
        {
          "id": "sent-012",
          "text": "Pero pasan dos meses.",
          "translationRu": "Но проходит два месяца."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Encuentran la cúpula de cristal.",
          "translationRu": "Они находят стеклянный купол."
        },
        {
          "id": "sent-014",
          "text": "Dentro todo está oscuro.",
          "translationRu": "Внутри всё темно."
        },
        {
          "id": "sent-015",
          "text": "Ven los templos bajo el agua.",
          "translationRu": "Они видят храмы под водой."
        },
        {
          "id": "sent-016",
          "text": "La Atlántida está inundada.",
          "translationRu": "Атлантида затоплена."
        },
        {
          "id": "sent-017",
          "text": "Llegaron demasiado tarde.",
          "translationRu": "Они опоздали."
        }
      ]
    }
  ]
}
