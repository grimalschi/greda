{
  "schemaVersion": "1.0",
  "workId": "the-sunken-world",
  "level": "a1",
  "chapter": {
    "id": "chapter-008",
    "number": 8,
    "title": "Capítulo 8"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Harkness escribe un libro sobre el mundo de arriba.",
          "translationRu": "Харкнесс пишет книгу о верхнем мире."
        },
        {
          "id": "sent-002",
          "text": "Todos en la Atlántida leen el libro.",
          "translationRu": "Все в Атлантиде читают книгу."
        },
        {
          "id": "sent-003",
          "text": "La gente se asusta de la vida en la superficie.",
          "translationRu": "Люди пугаются жизни на поверхности."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Harkness se casa con Aelios.",
          "translationRu": "Харкнесс женится на Аэлиос."
        },
        {
          "id": "sent-005",
          "text": "Ellos viven felices en una casa bonita.",
          "translationRu": "Они счастливо живут в красивом доме."
        },
        {
          "id": "sent-006",
          "text": "Pasan muchos años.",
          "translationRu": "Проходит много лет."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Un día la grieta en la pared vuelve.",
          "translationRu": "Однажды трещина в стене возвращается."
        },
        {
          "id": "sent-008",
          "text": "Esta vez es más grande.",
          "translationRu": "На этот раз она больше."
        },
        {
          "id": "sent-009",
          "text": "El agua entra en la ciudad.",
          "translationRu": "Вода входит в город."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Las luces de la Atlántida se apagan.",
          "translationRu": "Огни Атлантиды гаснут."
        },
        {
          "id": "sent-011",
          "text": "La gente corre por las calles inundadas.",
          "translationRu": "Люди бегут по затопленным улицам."
        },
        {
          "id": "sent-012",
          "text": "Todo es caos y miedo.",
          "translationRu": "Всюду хаос и страх."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "El jefe de la Atlántida llama a Harkness.",
          "translationRu": "Глава Атлантиды вызывает Харкнесса."
        },
        {
          "id": "sent-014",
          "text": "Dice: necesitamos ayuda del mundo de arriba.",
          "translationRu": "Он говорит: нам нужна помощь верхнего мира."
        },
        {
          "id": "sent-015",
          "text": "Harkness debe ir a buscarla.",
          "translationRu": "Харкнесс должен отправиться за ней."
        },
        {
          "id": "sent-016",
          "text": "Harkness acepta.",
          "translationRu": "Харкнесс соглашается."
        }
      ]
    }
  ]
}
