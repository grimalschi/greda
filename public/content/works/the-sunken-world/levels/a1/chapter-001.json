{
  "schemaVersion": "1.0",
  "workId": "the-sunken-world",
  "level": "a1",
  "chapter": {
    "id": "chapter-001",
    "number": 1,
    "title": "Capítulo 1"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Es el año 1918.",
          "translationRu": "Идёт 1918 год."
        },
        {
          "id": "sent-002",
          "text": "Hay una guerra grande en Europa.",
          "translationRu": "В Европе идёт большая война."
        },
        {
          "id": "sent-003",
          "text": "El submarino X-111 está en el océano Atlántico.",
          "translationRu": "Подводная лодка X-111 находится в Атлантическом океане."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "El capitán Gavison manda el barco.",
          "translationRu": "Капитан Гэвисон командует кораблём."
        },
        {
          "id": "sent-005",
          "text": "Anson Harkness es un oficial joven.",
          "translationRu": "Энсон Харкнесс — молодой офицер."
        },
        {
          "id": "sent-006",
          "text": "Hay muchos hombres en el submarino.",
          "translationRu": "На подводной лодке много людей."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "El motor del barco tiene un problema.",
          "translationRu": "Двигатель корабля неисправен."
        },
        {
          "id": "sent-008",
          "text": "Un torpedo alemán golpea el submarino.",
          "translationRu": "Немецкая торпеда попадает в подводную лодку."
        },
        {
          "id": "sent-009",
          "text": "El barco baja muy rápido.",
          "translationRu": "Корабль быстро погружается."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "El agua está muy oscura.",
          "translationRu": "Вода очень тёмная."
        },
        {
          "id": "sent-011",
          "text": "Los hombres tienen miedo.",
          "translationRu": "Люди напуганы."
        },
        {
          "id": "sent-012",
          "text": "El barco baja más y más.",
          "translationRu": "Корабль опускается всё глубже."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Harkness ve unas luces extrañas muy abajo.",
          "translationRu": "Харкнесс видит странные огни далеко внизу."
        },
        {
          "id": "sent-014",
          "text": "El barco da vueltas en el agua.",
          "translationRu": "Корабль вращается в воде."
        },
        {
          "id": "sent-015",
          "text": "Todo es caos dentro del submarino.",
          "translationRu": "Внутри подводной лодки царит хаос."
        }
      ]
    }
  ]
}
