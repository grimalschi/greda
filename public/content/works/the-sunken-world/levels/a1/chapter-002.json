{
  "schemaVersion": "1.0",
  "workId": "the-sunken-world",
  "level": "a1",
  "chapter": {
    "id": "chapter-002",
    "number": 2,
    "title": "Capítulo 2"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Los hombres se despiertan.",
          "translationRu": "Люди приходят в себя."
        },
        {
          "id": "sent-002",
          "text": "El submarino no está roto.",
          "translationRu": "Подводная лодка цела."
        },
        {
          "id": "sent-003",
          "text": "El medidor dice: cuarenta y dos metros.",
          "translationRu": "Глубиномер показывает: сорок два метра."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "El barco sube a la superficie.",
          "translationRu": "Корабль поднимается к поверхности."
        },
        {
          "id": "sent-005",
          "text": "Harkness abre la escotilla.",
          "translationRu": "Харкнесс открывает люк."
        },
        {
          "id": "sent-006",
          "text": "Hay un río extraño.",
          "translationRu": "Есть странная река."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "El cielo no existe aquí.",
          "translationRu": "Здесь нет неба."
        },
        {
          "id": "sent-008",
          "text": "Hay grandes columnas de piedra.",
          "translationRu": "Есть большие каменные колонны."
        },
        {
          "id": "sent-009",
          "text": "Unas esferas doradas dan luz.",
          "translationRu": "Золотые шары дают свет."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "El capitán clava la bandera americana.",
          "translationRu": "Капитан водружает американский флаг."
        },
        {
          "id": "sent-011",
          "text": "De repente las luces se apagan.",
          "translationRu": "Вдруг огни гаснут."
        },
        {
          "id": "sent-012",
          "text": "Un sonido terrible llena el aire.",
          "translationRu": "Ужасный звук наполняет воздух."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Los hombres corren al submarino.",
          "translationRu": "Люди бегут к подводной лодке."
        },
        {
          "id": "sent-014",
          "text": "Al día siguiente las luces vuelven.",
          "translationRu": "На следующий день огни возвращаются."
        },
        {
          "id": "sent-015",
          "text": "Cuatro hombres salen a explorar y no regresan.",
          "translationRu": "Четыре человека уходят на разведку и не возвращаются."
        },
        {
          "id": "sent-016",
          "text": "Harkness y Rawson van a buscarlos.",
          "translationRu": "Харкнесс и Роусон идут их искать."
        }
      ]
    }
  ]
}
