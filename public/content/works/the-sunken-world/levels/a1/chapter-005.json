{
  "schemaVersion": "1.0",
  "workId": "the-sunken-world",
  "level": "a1",
  "chapter": {
    "id": "chapter-005",
    "number": 5,
    "title": "Capítulo 5"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "El capitán Gavison llega con el resto de la tripulación.",
          "translationRu": "Капитан Гэвисон прибывает с остальной командой."
        },
        {
          "id": "sent-002",
          "text": "Todos están en el gran salón.",
          "translationRu": "Все оказываются в большом зале."
        },
        {
          "id": "sent-003",
          "text": "Hay un juicio.",
          "translationRu": "Проходит суд."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Un hombre alto acusa a los marineros.",
          "translationRu": "Высокий мужчина обвиняет моряков."
        },
        {
          "id": "sent-005",
          "text": "Dice que ellos dañaron el agua y los cangrejos.",
          "translationRu": "Он говорит, что они отравили воду и навредили крабам."
        },
        {
          "id": "sent-006",
          "text": "Harkness habla en defensa de los marineros.",
          "translationRu": "Харкнесс говорит в защиту моряков."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Los jueces toman una decisión.",
          "translationRu": "Судьи принимают решение."
        },
        {
          "id": "sent-008",
          "text": "Los marineros deben vivir en la Atlántida para siempre.",
          "translationRu": "Моряки должны жить в Атлантиде навсегда."
        },
        {
          "id": "sent-009",
          "text": "No pueden regresar al mundo de arriba.",
          "translationRu": "Они не могут вернуться в верхний мир."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "El capitán Gavison crea el Club del Mundo de Arriba.",
          "translationRu": "Капитан Гэвисон создаёт Клуб Верхнего Мира."
        },
        {
          "id": "sent-011",
          "text": "Todos los marineros son miembros.",
          "translationRu": "Все моряки становятся членами."
        },
        {
          "id": "sent-012",
          "text": "El club da a los hombres un poco de esperanza.",
          "translationRu": "Клуб даёт людям немного надежды."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Harkness habla con Aelios.",
          "translationRu": "Харкнесс разговаривает с Аэлиос."
        },
        {
          "id": "sent-014",
          "text": "Ella le cuenta la historia de la Atlántida.",
          "translationRu": "Она рассказывает ему историю Атлантиды."
        },
        {
          "id": "sent-015",
          "text": "La civilización tiene siete mil años.",
          "translationRu": "Цивилизации семь тысяч лет."
        },
        {
          "id": "sent-016",
          "text": "Agripides propuso hundir el continente.",
          "translationRu": "Агрипид предложил утопить континент."
        }
      ]
    }
  ]
}
