{
  "schemaVersion": "1.0",
  "workId": "cities-in-the-air",
  "level": "a1",
  "chapter": {
    "id": "chapter-002",
    "number": 2,
    "title": "Capítulo 2"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Volamos sobre el océano Atlántico.",
          "translationRu": "Мы летим над Атлантическим океаном."
        },
        {
          "id": "sent-002",
          "text": "Veo muchos puntos negros en el cielo.",
          "translationRu": "Я вижу много чёрных точек в небе."
        },
        {
          "id": "sent-003",
          "text": "Son los cruceros del enemigo.",
          "translationRu": "Это крейсеры врага."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "La batalla empieza.",
          "translationRu": "Битва начинается."
        },
        {
          "id": "sent-005",
          "text": "Los cruceros luchan con bombas de calor.",
          "translationRu": "Крейсеры сражаются тепловыми бомбами."
        },
        {
          "id": "sent-006",
          "text": "Las bombas hacen mucho fuego y calor.",
          "translationRu": "Бомбы производят много огня и тепла."
        },
        {
          "id": "sent-007",
          "text": "Muchos cruceros caen al mar.",
          "translationRu": "Много крейсеров падают в море."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-008",
          "text": "El enemigo tiene más cruceros que nosotros.",
          "translationRu": "У врага больше крейсеров, чем у нас."
        },
        {
          "id": "sent-009",
          "text": "La situación es difícil.",
          "translationRu": "Ситуация трудная."
        },
        {
          "id": "sent-010",
          "text": "El jefe dice: ¡Huimos!",
          "translationRu": "Начальник говорит: бегите!"
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-011",
          "text": "Huimos hacia el oeste.",
          "translationRu": "Мы бежим на запад."
        },
        {
          "id": "sent-012",
          "text": "El enemigo viene detrás de nosotros.",
          "translationRu": "Враг идёт за нами."
        },
        {
          "id": "sent-013",
          "text": "Buscamos las fortalezas del aire.",
          "translationRu": "Мы ищем воздушные крепости."
        },
        {
          "id": "sent-014",
          "text": "Pero no vemos las fortalezas.",
          "translationRu": "Но мы не видим крепости."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-015",
          "text": "El jefe entra en una nube grande.",
          "translationRu": "Начальник входит в большое облако."
        },
        {
          "id": "sent-016",
          "text": "El enemigo entra en la nube también.",
          "translationRu": "Враг тоже входит в облако."
        },
        {
          "id": "sent-017",
          "text": "No se puede ver nada en la nube.",
          "translationRu": "В облаке ничего не видно."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-018",
          "text": "El jefe da una orden: ¡Caigan!",
          "translationRu": "Начальник даёт приказ: падайте!"
        },
        {
          "id": "sent-019",
          "text": "Nuestros cruceros caen bajo la nube.",
          "translationRu": "Наши крейсеры падают под облако."
        },
        {
          "id": "sent-020",
          "text": "La nube desaparece.",
          "translationRu": "Облако исчезает."
        },
        {
          "id": "sent-021",
          "text": "Las fortalezas del aire están ahí.",
          "translationRu": "Воздушные крепости там."
        },
        {
          "id": "sent-022",
          "text": "El enemigo está entre las fortalezas.",
          "translationRu": "Враг находится между крепостями."
        }
      ]
    },
    {
      "id": "para-007",
      "sentences": [
        {
          "id": "sent-023",
          "text": "Las fortalezas atacan al enemigo.",
          "translationRu": "Крепости атакуют врага."
        },
        {
          "id": "sent-024",
          "text": "El enemigo huye hacia el este.",
          "translationRu": "Враг бежит на восток."
        },
        {
          "id": "sent-025",
          "text": "¡Ganamos la primera batalla!",
          "translationRu": "Мы выиграли первую битву!"
        }
      ]
    }
  ]
}
