{
  "schemaVersion": "1.0",
  "workId": "cities-in-the-air",
  "level": "a1",
  "chapter": {
    "id": "chapter-003",
    "number": 3,
    "title": "Capítulo 3"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "El jefe tiene un plan nuevo.",
          "translationRu": "У начальника есть новый план."
        },
        {
          "id": "sent-002",
          "text": "El plan es atacar Berlín.",
          "translationRu": "План — атаковать Берлин."
        },
        {
          "id": "sent-003",
          "text": "Berlín es la capital de la Federación Europea.",
          "translationRu": "Берлин — это столица Европейской федерации."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Yo voy con doscientos cincuenta cruceros.",
          "translationRu": "Я лечу с двумястами пятьюдесятью крейсерами."
        },
        {
          "id": "sent-005",
          "text": "Volamos sobre el Atlántico de noche.",
          "translationRu": "Мы летим над Атлантикой ночью."
        },
        {
          "id": "sent-006",
          "text": "Hay patrullas enemigas en el cielo.",
          "translationRu": "В небе есть вражеские патрули."
        },
        {
          "id": "sent-007",
          "text": "Pasamos sin ruido.",
          "translationRu": "Мы проходим без шума."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-008",
          "text": "Hay fortalezas europeas en el camino.",
          "translationRu": "На пути есть европейские крепости."
        },
        {
          "id": "sent-009",
          "text": "Las fortalezas tienen bombas en el aire.",
          "translationRu": "У крепостей есть бомбы в воздухе."
        },
        {
          "id": "sent-010",
          "text": "Volamos entre las bombas con cuidado.",
          "translationRu": "Мы летим между бомбами осторожно."
        },
        {
          "id": "sent-011",
          "text": "Todos los cruceros pasan.",
          "translationRu": "Все крейсеры проходят."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Vemos Berlín en el cielo.",
          "translationRu": "Мы видим Берлин в небе."
        },
        {
          "id": "sent-013",
          "text": "Berlín es una ciudad grande con muchas luces.",
          "translationRu": "Берлин — большой город с множеством огней."
        },
        {
          "id": "sent-014",
          "text": "La ciudad está a cuatro millas de altura.",
          "translationRu": "Город находится на высоте четырёх миль."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-015",
          "text": "Atacamos con bombas de calor.",
          "translationRu": "Мы атакуем тепловыми бомбами."
        },
        {
          "id": "sent-016",
          "text": "Las bombas destruyen los arsenales del este.",
          "translationRu": "Бомбы разрушают восточные арсеналы."
        },
        {
          "id": "sent-017",
          "text": "Después atacamos los arsenales del oeste.",
          "translationRu": "Затем мы атакуем западные арсеналы."
        },
        {
          "id": "sent-018",
          "text": "Hay mucho fuego y muchas explosiones.",
          "translationRu": "Много огня и много взрывов."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-019",
          "text": "Dos cruceros enemigos atacan mi barco.",
          "translationRu": "Два вражеских крейсера атакуют мой корабль."
        },
        {
          "id": "sent-020",
          "text": "Mi crucero cae hacia la ciudad.",
          "translationRu": "Мой крейсер падает в сторону города."
        },
        {
          "id": "sent-021",
          "text": "Hay un choque fuerte.",
          "translationRu": "Есть сильный удар."
        },
        {
          "id": "sent-022",
          "text": "Yo pierdo el conocimiento.",
          "translationRu": "Я теряю сознание."
        }
      ]
    },
    {
      "id": "para-007",
      "sentences": [
        {
          "id": "sent-023",
          "text": "Me despierto en una habitación blanca.",
          "translationRu": "Я просыпаюсь в белой комнате."
        },
        {
          "id": "sent-024",
          "text": "Macklin e Hilliard están aquí.",
          "translationRu": "Маклин и Хиллиард здесь."
        },
        {
          "id": "sent-025",
          "text": "Hay soldados europeos con pistolas.",
          "translationRu": "Есть европейские солдаты с пистолетами."
        },
        {
          "id": "sent-026",
          "text": "Somos prisioneros en Berlín.",
          "translationRu": "Мы пленники в Берлине."
        }
      ]
    }
  ]
}
