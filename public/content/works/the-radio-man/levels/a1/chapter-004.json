{
  "schemaVersion": "1.0",
  "workId": "the-radio-man",
  "level": "a1",
  "chapter": {
    "id": "chapter-004",
    "number": 4,
    "title": "Capítulo 4"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Un día Myles ve una chica en el jardín.",
          "translationRu": "Однажды Майлс видит девушку в саду."
        },
        {
          "id": "sent-002",
          "text": "Ella es muy bonita.",
          "translationRu": "Она очень красивая."
        },
        {
          "id": "sent-003",
          "text": "Tiene alas pequeñas en la espalda.",
          "translationRu": "У неё маленькие крылья на спине."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Doggo dice que ella es una «cupiana».",
          "translationRu": "Догго говорит, что она «купианка»."
        },
        {
          "id": "sent-005",
          "text": "Los cupianos son personas de este mundo.",
          "translationRu": "Купиане — люди этого мира."
        },
        {
          "id": "sent-006",
          "text": "Myles quiere hablar con ella.",
          "translationRu": "Майлс хочет поговорить с ней."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Myles tiene una idea.",
          "translationRu": "Майлс придумывает идею."
        },
        {
          "id": "sent-008",
          "text": "Las hormigas y los cupianos usan la radio para hablar.",
          "translationRu": "Муравьи и купиане используют радио для разговора."
        },
        {
          "id": "sent-009",
          "text": "Myles puede construir una radio especial.",
          "translationRu": "Майлс может построить специальное радио."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Myles va a la universidad de Mooni.",
          "translationRu": "Майлс отправляется в университет Моони."
        },
        {
          "id": "sent-011",
          "text": "Él trabaja mucho en el laboratorio.",
          "translationRu": "Он много работает в лаборатории."
        },
        {
          "id": "sent-012",
          "text": "Después de cuatro meses, la radio funciona.",
          "translationRu": "Через четыре месяца радио работает."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Myles regresa a la ciudad.",
          "translationRu": "Майлс возвращается в город."
        },
        {
          "id": "sent-014",
          "text": "Él habla con la chica cupiana.",
          "translationRu": "Он разговаривает с купианской девушкой."
        },
        {
          "id": "sent-015",
          "text": "La chica escucha su voz.",
          "translationRu": "Девушка слышит его голос."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Myles aprende que ella es la Princesa Lilla.",
          "translationRu": "Майлс узнаёт, что она — Принцесса Лилла."
        },
        {
          "id": "sent-017",
          "text": "Las hormigas la tienen prisionera.",
          "translationRu": "Муравьи держат её в плену."
        },
        {
          "id": "sent-018",
          "text": "Myles quiere salvarla.",
          "translationRu": "Майлс хочет её спасти."
        }
      ]
    }
  ]
}
