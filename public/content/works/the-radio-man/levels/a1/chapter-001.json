  "level": "a1",
  "chapter": {
    "id": "chapter-001",
    "number": 1,
    "title": "Capítulo 1"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Myles Cabot vive en Boston.",
          "translationRu": "Майлс Кэбот живёт в Бостоне."
        },
        {
          "id": "sent-002",
          "text": "Él trabaja con la radio.",
          "translationRu": "Он работает с радио."
        },
        {
          "id": "sent-003",
          "text": "Un día, hay un accidente en su laboratorio.",
          "translationRu": "Однажды в его лаборатории происходит несчастный случай."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Un meteorito cae cerca de la casa de Ralph Farley.",
          "translationRu": "Метеорит падает рядом с домом Ральфа Фарли."
        },
        {
          "id": "sent-005",
          "text": "Ralph es el amigo de Myles.",
          "translationRu": "Ральф — друг Майлса."
        },
        {
          "id": "sent-006",
          "text": "Ralph encuentra el meteorito en una colina.",
          "translationRu": "Ральф находит метеорит на холме."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "El meteorito es grande y negro.",
          "translationRu": "Метеорит большой и чёрный."
        },
        {
          "id": "sent-008",
          "text": "Ralph ve metal amarillo dentro.",
          "translationRu": "Ральф видит жёлтый металл внутри."
        },
        {
          "id": "sent-009",
          "text": "Hay una línea en el metal.",
          "translationRu": "На металле есть линия."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Ralph y sus hombres abren el meteorito.",
          "translationRu": "Ральф и его люди открывают метеорит."
        },
        {
          "id": "sent-011",
          "text": "Dentro hay un cilindro de oro.",
          "translationRu": "Внутри находится золотой цилиндр."
        },
        {
          "id": "sent-012",
          "text": "El cilindro tiene un manuscrito.",
          "translationRu": "Цилиндр содержит рукопись."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "El manuscrito es de Myles Cabot.",
          "translationRu": "Рукопись от Майлса Кэбота."
        },
        {
          "id": "sent-014",
          "text": "Myles desapareció hace cuatro años.",
          "translationRu": "Майлс исчез четыре года назад."
        },
        {
          "id": "sent-015",
          "text": "Nadie sabe dónde está Myles.",
          "translationRu": "Никто не знает, где Майлс."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Ralph lee el manuscrito.",
          "translationRu": "Ральф читает рукопись."
        },
        {
          "id": "sent-017",
          "text": "Myles escribe sobre su vida en otro mundo.",
          "translationRu": "Майлс пишет о своей жизни в другом мире."
        }
      ]
    }
  ]
}
