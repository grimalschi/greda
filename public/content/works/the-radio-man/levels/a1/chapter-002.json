{
  "schemaVersion": "1.0",
  "workId": "the-radio-man",
  "level": "a1",
  "chapter": {
    "id": "chapter-002",
    "number": 2,
    "title": "Capítulo 2"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Myles trabaja en su laboratorio.",
          "translationRu": "Майлс работает в своей лаборатории."
        },
        {
          "id": "sent-002",
          "text": "Hay una luz grande y Myles pierde el conocimiento.",
          "translationRu": "Появляется яркая вспышка, и Майлс теряет сознание."
        },
        {
          "id": "sent-003",
          "text": "Myles despierta en un mundo nuevo.",
          "translationRu": "Майлс просыпается в новом мире."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Está en una playa blanca.",
          "translationRu": "Он находится на белом пляже."
        },
        {
          "id": "sent-005",
          "text": "El cielo es gris y brillante.",
          "translationRu": "Небо серое и яркое."
        },
        {
          "id": "sent-006",
          "text": "El aire es cálido y húmedo.",
          "translationRu": "Воздух тёплый и влажный."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Myles ve un avión.",
          "translationRu": "Майлс видит самолёт."
        },
        {
          "id": "sent-008",
          "text": "El avión aterriza cerca.",
          "translationRu": "Самолёт приземляется рядом."
        },
        {
          "id": "sent-009",
          "text": "De él salen cuatro hormigas grandes.",
          "translationRu": "Из него выходят четыре большие муравьи."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Las hormigas son enormes.",
          "translationRu": "Муравьи огромные."
        },
        {
          "id": "sent-011",
          "text": "Myles lucha con ellas.",
          "translationRu": "Майлс сражается с ними."
        },
        {
          "id": "sent-012",
          "text": "Myles pierde y las hormigas lo capturan.",
          "translationRu": "Майлс проигрывает, и муравьи его захватывают."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Myles está en el avión.",
          "translationRu": "Майлс находится в самолёте."
        },
        {
          "id": "sent-014",
          "text": "No puede mover el cuerpo.",
          "translationRu": "Он не может двигать телом."
        },
        {
          "id": "sent-015",
          "text": "Una hormiga le da agua.",
          "translationRu": "Один муравей даёт ему воды."
        },
        {
          "id": "sent-016",
          "text": "Myles llama a esa hormiga amiga «Doggo».",
          "translationRu": "Майлс называет эту дружелюбную муравью «Догго»."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-017",
          "text": "El avión vuela sobre un bosque.",
          "translationRu": "Самолёт летит над лесом."
        },
        {
          "id": "sent-018",
          "text": "De repente, el avión da una vuelta.",
          "translationRu": "Вдруг самолёт делает петлю."
        },
        {
          "id": "sent-019",
          "text": "Myles cae del avión.",
          "translationRu": "Майлс падает из самолёта."
        }
      ]
    },
    {
      "id": "para-007",
      "sentences": [
        {
          "id": "sent-020",
          "text": "Myles cae en una tela grande.",
          "translationRu": "Майлс падает в большую паутину."
        },
        {
          "id": "sent-021",
          "text": "Es la telaraña de una araña gigante.",
          "translationRu": "Это паутина гигантского паука."
        },
        {
          "id": "sent-022",
          "text": "La araña envuelve a Myles.",
          "translationRu": "Паук обматывает Майлса."
        }
      ]
    }
  ]
}
