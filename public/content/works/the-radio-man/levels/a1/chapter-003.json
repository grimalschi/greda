{
  "schemaVersion": "1.0",
  "workId": "the-radio-man",
  "level": "a1",
  "chapter": {
    "id": "chapter-003",
    "number": 3,
    "title": "Capítulo 3"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Una abeja grande cae en la telaraña.",
          "translationRu": "В паутину падает большая пчела."
        },
        {
          "id": "sent-002",
          "text": "La abeja lucha con la araña.",
          "translationRu": "Пчела сражается с пауком."
        },
        {
          "id": "sent-003",
          "text": "La abeja mata a la araña.",
          "translationRu": "Пчела убивает паука."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Myles sale de la telaraña.",
          "translationRu": "Майлс выбирается из паутины."
        },
        {
          "id": "sent-005",
          "text": "Él ayuda a la abeja.",
          "translationRu": "Он помогает пчеле."
        },
        {
          "id": "sent-006",
          "text": "La abeja vuela libre.",
          "translationRu": "Пчела улетает на свободу."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Myles camina por un camino de concreto.",
          "translationRu": "Майлс идёт по бетонной дороге."
        },
        {
          "id": "sent-008",
          "text": "Tiene hambre y está muy cansado.",
          "translationRu": "Он голоден и очень устал."
        },
        {
          "id": "sent-009",
          "text": "Ve una planta con un olor dulce.",
          "translationRu": "Он видит растение со сладким запахом."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Myles toca la planta.",
          "translationRu": "Майлс прикасается к растению."
        },
        {
          "id": "sent-011",
          "text": "La planta cierra su boca sobre su brazo.",
          "translationRu": "Растение захлопывает пасть на его руке."
        },
        {
          "id": "sent-012",
          "text": "La planta intenta comer a Myles.",
          "translationRu": "Растение пытается съесть Майлса."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Doggo llega y salva a Myles.",
          "translationRu": "Догго приходит и спасает Майлса."
        },
        {
          "id": "sent-014",
          "text": "Doggo lleva a Myles en sus mandíbulas.",
          "translationRu": "Догго несёт Майлса в челюстях."
        },
        {
          "id": "sent-015",
          "text": "Myles está muy contento.",
          "translationRu": "Майлс очень рад."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Las hormigas llevan a Myles a una ciudad.",
          "translationRu": "Муравьи несут Майлса в город."
        },
        {
          "id": "sent-017",
          "text": "La ciudad tiene muchas habitaciones y pasillos.",
          "translationRu": "В городе много комнат и коридоров."
        },
        {
          "id": "sent-018",
          "text": "Myles tiene una cama y ropa nueva.",
          "translationRu": "У Майлса есть кровать и новая одежда."
        }
      ]
    },
    {
      "id": "para-007",
      "sentences": [
        {
          "id": "sent-019",
          "text": "Doggo enseña a Myles el idioma de las hormigas.",
          "translationRu": "Догго учит Майлса языку муравьёв."
        },
        {
          "id": "sent-020",
          "text": "Ellos escriben palabras en papel.",
          "translationRu": "Они пишут слова на бумаге."
        },
        {
          "id": "sent-021",
          "text": "Myles aprende rápido.",
          "translationRu": "Майлс учится быстро."
        }
      ]
    }
  ]
}
