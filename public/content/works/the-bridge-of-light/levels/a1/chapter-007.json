{
  "schemaVersion": "1.0",
  "workId": "the-bridge-of-light",
  "level": "a1",
  "chapter": {
    "id": "chapter-007",
    "number": 7,
    "title": "Capítulo 7"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Invento la rueda para el pueblo de Mictolán.",
          "translationRu": "Я изобретаю колесо для народа Миктолана."
        },
        {
          "id": "sent-002",
          "text": "Los mayas nunca conocieron la rueda.",
          "translationRu": "Майя никогда не знали колеса."
        },
        {
          "id": "sent-003",
          "text": "Uso los husos de las mujeres para hacer una rueda pequeña.",
          "translationRu": "Я использую женские веретёна, чтобы сделать маленькое колесо."
        },
        {
          "id": "sent-004",
          "text": "El pueblo está muy contento.",
          "translationRu": "Народ очень доволен."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-005",
          "text": "Después construyo un molino de viento.",
          "translationRu": "Потом я строю ветряную мельницу."
        },
        {
          "id": "sent-006",
          "text": "El viento mueve las aspas del molino.",
          "translationRu": "Ветер вращает лопасти мельницы."
        },
        {
          "id": "sent-007",
          "text": "El molino saca agua del río.",
          "translationRu": "Мельница качает воду из реки."
        },
        {
          "id": "sent-008",
          "text": "El pueblo lleva el agua en ollas.",
          "translationRu": "Народ носит воду в горшках."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-009",
          "text": "También construyo una rueda de agua.",
          "translationRu": "Я также строю водяное колесо."
        },
        {
          "id": "sent-010",
          "text": "La rueda muele el maíz.",
          "translationRu": "Колесо мелет кукурузу."
        },
        {
          "id": "sent-011",
          "text": "El pueblo baila y canta de alegría.",
          "translationRu": "Народ танцует и поёт от радости."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Luego hago herramientas de hierro.",
          "translationRu": "Потом я делаю железные инструменты."
        },
        {
          "id": "sent-013",
          "text": "El hierro es más duro que el cobre.",
          "translationRu": "Железо твёрже меди."
        },
        {
          "id": "sent-014",
          "text": "Con el hierro también hago armas para escapar del valle.",
          "translationRu": "Из железа я также делаю оружие, чтобы сбежать из долины."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-015",
          "text": "Enseño inglés a Itza todos los días.",
          "translationRu": "Я учу Итцу английскому языку каждый день."
        },
        {
          "id": "sent-016",
          "text": "Ella aprende muy rápido.",
          "translationRu": "Она учится очень быстро."
        },
        {
          "id": "sent-017",
          "text": "Me caso con Itza delante del príncipe Azcopil.",
          "translationRu": "Я женюсь на Итце перед принцем Акопилем."
        },
        {
          "id": "sent-018",
          "text": "Ahora ella es mi esposa.",
          "translationRu": "Теперь она моя жена."
        }
      ]
    }
  ]
}
