{
  "schemaVersion": "1.0",
  "workId": "the-bridge-of-light",
  "level": "a1",
  "chapter": {
    "id": "chapter-001",
    "number": 1,
    "title": "Capítulo 1"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Yo soy científico.",
          "translationRu": "Я учёный."
        },
        {
          "id": "sent-002",
          "text": "Estudio las culturas antiguas.",
          "translationRu": "Я изучаю древние культуры."
        },
        {
          "id": "sent-003",
          "text": "Un día voy a una tienda en Vigo, España.",
          "translationRu": "Однажды я иду в магазин в Виго, Испания."
        },
        {
          "id": "sent-004",
          "text": "El dueño se llama Miguel.",
          "translationRu": "Хозяина зовут Мигель."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-005",
          "text": "Compro dos libros viejos.",
          "translationRu": "Я покупаю две старые книги."
        },
        {
          "id": "sent-006",
          "text": "De uno de los libros cae un papel.",
          "translationRu": "Из одной книги выпадает бумага."
        },
        {
          "id": "sent-007",
          "text": "El papel tiene figuras de colores.",
          "translationRu": "На бумаге есть цветные фигуры."
        },
        {
          "id": "sent-008",
          "text": "Pago dos pesos más y me lo llevo.",
          "translationRu": "Я плачу ещё два песо и забираю его."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-009",
          "text": "En el barco abro el libro.",
          "translationRu": "На корабле я открываю книгу."
        },
        {
          "id": "sent-010",
          "text": "Veo el papel y me sorprendo mucho.",
          "translationRu": "Я вижу бумагу и очень удивляюсь."
        },
        {
          "id": "sent-011",
          "text": "Es un códice maya muy antiguo.",
          "translationRu": "Это очень старый майянский кодекс."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Voy a Londres con el códice.",
          "translationRu": "Я еду в Лондон с кодексом."
        },
        {
          "id": "sent-013",
          "text": "Muchos expertos lo ven.",
          "translationRu": "Многие эксперты смотрят на него."
        },
        {
          "id": "sent-014",
          "text": "Dicen que es muy importante.",
          "translationRu": "Они говорят, что он очень важен."
        },
        {
          "id": "sent-015",
          "text": "Pero nadie puede leerlo.",
          "translationRu": "Но никто не может его прочитать."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Voy a México y hablo con el Profesor Cervantes.",
          "translationRu": "Я еду в Мексику и разговариваю с профессором Серванте́с."
        },
        {
          "id": "sent-017",
          "text": "Él me dice: «Ve a Guatemala».",
          "translationRu": "Он говорит мне: «Поезжай в Гватемалу»."
        },
        {
          "id": "sent-018",
          "text": "Allí vive un sacerdote que sabe leer los glifos mayas.",
          "translationRu": "Там живёт священник, который умеет читать майянские глифы."
        }
      ]
    }
  ]
}
