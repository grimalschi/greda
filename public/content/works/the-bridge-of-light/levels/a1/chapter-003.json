{
  "schemaVersion": "1.0",
  "workId": "the-bridge-of-light",
  "level": "a1",
  "chapter": {
    "id": "chapter-003",
    "number": 3,
    "title": "Capítulo 3"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Katchilcán me cuenta la profecía.",
          "translationRu": "Кат чилькан рассказывает мне пророчество."
        },
        {
          "id": "sent-002",
          "text": "Dice que el códice es el libro de Kukulcán.",
          "translationRu": "Он говорит, что кодекс — это книга Кукулькана."
        },
        {
          "id": "sent-003",
          "text": "El libro tiene un símbolo muy especial.",
          "translationRu": "В книге есть особый символ."
        },
        {
          "id": "sent-004",
          "text": "Ese símbolo lleva a la ciudad escondida de Mictolán.",
          "translationRu": "Этот символ ведёт к скрытому городу Миктолан."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-005",
          "text": "Decido ir a buscar la ciudad.",
          "translationRu": "Я решаю идти искать город."
        },
        {
          "id": "sent-006",
          "text": "Salgo con cuatro indios que conocen el camino.",
          "translationRu": "Я выхожу с четырьмя индейцами, знающими дорогу."
        },
        {
          "id": "sent-007",
          "text": "Viajamos muchos días.",
          "translationRu": "Мы путешествуем много дней."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-008",
          "text": "Un día encontramos un templo antiguo.",
          "translationRu": "Однажды мы находим старый храм."
        },
        {
          "id": "sent-009",
          "text": "Dentro hay muchos indios que rezan a un dios.",
          "translationRu": "Внутри много индейцев, молящихся богу."
        },
        {
          "id": "sent-010",
          "text": "Me atrapan.",
          "translationRu": "Они захватывают меня."
        },
        {
          "id": "sent-011",
          "text": "El jefe ve el códice y me suelta.",
          "translationRu": "Вождь видит кодекс и освобождает меня."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Mis indios huyen.",
          "translationRu": "Мои индейцы убегают."
        },
        {
          "id": "sent-013",
          "text": "El jefe se llama Maliche.",
          "translationRu": "Вождя зовут Маличе."
        },
        {
          "id": "sent-014",
          "text": "Maliche y sus hombres llevan mis cosas.",
          "translationRu": "Маличе и его люди несут мои вещи."
        },
        {
          "id": "sent-015",
          "text": "Seguimos el camino juntos.",
          "translationRu": "Мы продолжаем путь вместе."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Veo dos volcanes en la distancia.",
          "translationRu": "Я вижу два вулкана вдали."
        },
        {
          "id": "sent-017",
          "text": "El códice habla de «dos montañas de fuego».",
          "translationRu": "Кодекс говорит о «двух огненных горах»."
        },
        {
          "id": "sent-018",
          "text": "¡Estoy en el camino correcto!",
          "translationRu": "Я на правильном пути!"
        }
      ]
    }
  ]
}
