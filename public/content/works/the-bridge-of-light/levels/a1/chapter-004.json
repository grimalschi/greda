{
  "schemaVersion": "1.0",
  "workId": "the-bridge-of-light",
  "level": "a1",
  "chapter": {
    "id": "chapter-004",
    "number": 4,
    "title": "Capítulo 4"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Llegamos a un cañón muy profundo.",
          "translationRu": "Мы приходим к очень глубокому каньону."
        },
        {
          "id": "sent-002",
          "text": "Hay un río dentro del cañón.",
          "translationRu": "Внутри каньона есть река."
        },
        {
          "id": "sent-003",
          "text": "Dormimos en una cueva cerca del río.",
          "translationRu": "Мы спим в пещере рядом с рекой."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "De noche hay una tormenta muy grande.",
          "translationRu": "Ночью начинается очень сильная гроза."
        },
        {
          "id": "sent-005",
          "text": "El río sube mucho.",
          "translationRu": "Река сильно поднимается."
        },
        {
          "id": "sent-006",
          "text": "Casi todos los indios mueren.",
          "translationRu": "Почти все индейцы погибают."
        },
        {
          "id": "sent-007",
          "text": "Solo Maliche y yo sobrevivimos.",
          "translationRu": "Выживаем только Маличе и я."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-008",
          "text": "Encontramos una cueva en la pared del cañón.",
          "translationRu": "Мы находим пещеру в стене каньона."
        },
        {
          "id": "sent-009",
          "text": "La cueva es un túnel largo y oscuro.",
          "translationRu": "Пещера — это длинный тёмный туnel."
        },
        {
          "id": "sent-010",
          "text": "Entramos en el túnel.",
          "translationRu": "Мы входим в туннель."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-011",
          "text": "Dentro hay muchas serpientes de cascabel.",
          "translationRu": "Внутри много гремучих змей."
        },
        {
          "id": "sent-012",
          "text": "Tenemos mucho miedo.",
          "translationRu": "Мы очень боимся."
        },
        {
          "id": "sent-013",
          "text": "Un cerdo salvaje cae en el túnel.",
          "translationRu": "Дикий кабан падает в туннель."
        },
        {
          "id": "sent-014",
          "text": "El cerdo mata las serpientes.",
          "translationRu": "Кабан убивает змей."
        },
        {
          "id": "sent-015",
          "text": "Salimos del túnel.",
          "translationRu": "Мы выходим из туннеля."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Después cruzamos un lago negro con muchos caimanes.",
          "translationRu": "Потом мы переходим чёрное озеро с множеством крокодилов."
        },
        {
          "id": "sent-017",
          "text": "Es muy peligroso.",
          "translationRu": "Это очень опасно."
        },
        {
          "id": "sent-018",
          "text": "Cruzamos sobre un árbol caído.",
          "translationRu": "Мы переходим по упавшему дереву."
        }
      ]
    }
  ]
}
