{
  "schemaVersion": "1.0",
  "workId": "the-alien-intelligence",
  "level": "a1",
  "chapter": {
    "id": "chapter-003",
    "number": 3,
    "title": "Capítulo 3"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Por la mañana, estoy en la llanura roja.",
          "translationRu": "Утром я нахожусь на красной равнине."
        },
        {
          "id": "sent-002",
          "text": "Las plantas son rojas.",
          "translationRu": "Растения красные."
        },
        {
          "id": "sent-003",
          "text": "No hay animales.",
          "translationRu": "Животных нет."
        },
        {
          "id": "sent-004",
          "text": "Hay mucho silencio.",
          "translationRu": "Стоит полная тишина."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-005",
          "text": "Veo a unos soldados.",
          "translationRu": "Я вижу нескольких солдат."
        },
        {
          "id": "sent-006",
          "text": "Son altos y tienen el pelo rubio.",
          "translationRu": "Они высокие и светловолосые."
        },
        {
          "id": "sent-007",
          "text": "Tienen armas de cristal.",
          "translationRu": "У них оружие из кристалла."
        },
        {
          "id": "sent-008",
          "text": "Marchan hacia la montaña de cristal.",
          "translationRu": "Они маршируют к горе из кристалла."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-009",
          "text": "La ciudad en la montaña es de cristal.",
          "translationRu": "Город на горе из кристалла."
        },
        {
          "id": "sent-010",
          "text": "Brilla con muchos colores.",
          "translationRu": "Он сверкает множеством цветов."
        },
        {
          "id": "sent-011",
          "text": "Es muy bonita.",
          "translationRu": "Он очень красивый."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Veo a una chica en el campo.",
          "translationRu": "Я вижу девушку в поле."
        },
        {
          "id": "sent-013",
          "text": "Ella tiene el pelo dorado.",
          "translationRu": "У неё золотые волосы."
        },
        {
          "id": "sent-014",
          "text": "Es muy bella.",
          "translationRu": "Она очень красивая."
        },
        {
          "id": "sent-015",
          "text": "Habla en inglés.",
          "translationRu": "Она говорит по-английски."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Ella se llama Melvar.",
          "translationRu": "Её зовут Мелвар."
        },
        {
          "id": "sent-017",
          "text": "Ella conoce a Austen.",
          "translationRu": "Она знает Остена."
        },
        {
          "id": "sent-018",
          "text": "Austen está más allá del lago de plata.",
          "translationRu": "Остен находится за серебряным озером."
        }
      ]
    }
  ]
}
