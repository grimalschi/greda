{
  "schemaVersion": "1.0",
  "workId": "the-alien-intelligence",
  "level": "a1",
  "chapter": {
    "id": "chapter-001",
    "number": 1,
    "title": "Capítulo 1"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Yo me llamo Winfield Fowler.",
          "translationRu": "Меня зовут Уинфилд Фаулер."
        },
        {
          "id": "sent-002",
          "text": "Soy médico.",
          "translationRu": "Я врач."
        },
        {
          "id": "sent-003",
          "text": "Vivo en Perth, en Australia.",
          "translationRu": "Я живу в Перте, в Австралии."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Mi amigo se llama Horace Austen.",
          "translationRu": "Моего друга зовут Горас Остен."
        },
        {
          "id": "sent-005",
          "text": "Él es científico.",
          "translationRu": "Он учёный."
        },
        {
          "id": "sent-006",
          "text": "Un día, Austen va al desierto.",
          "translationRu": "Однажды Остен уходит в пустыню."
        },
        {
          "id": "sent-007",
          "text": "No vuelve.",
          "translationRu": "Он не возвращается."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-008",
          "text": "Un día, recibo un mensaje por radio.",
          "translationRu": "Однажды я получаю сообщение по радио."
        },
        {
          "id": "sent-009",
          "text": "El mensaje es de Austen.",
          "translationRu": "Сообщение от Остена."
        },
        {
          "id": "sent-010",
          "text": "Austen dice que está en un mundo nuevo y extraño.",
          "translationRu": "Остен говорит, что он в новом и странном мире."
        },
        {
          "id": "sent-011",
          "text": "Pide ayuda.",
          "translationRu": "Он просит о помощи."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Tomo mi rifle y mis pistolas.",
          "translationRu": "Я беру свою винтовку и пистолеты."
        },
        {
          "id": "sent-013",
          "text": "Viajo al desierto en poni.",
          "translationRu": "Я еду в пустыню на пони."
        },
        {
          "id": "sent-014",
          "text": "Después de tres semanas, veo la montaña.",
          "translationRu": "Через три недели я вижу гору."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-015",
          "text": "La montaña es grande y negra.",
          "translationRu": "Гора большая и чёрная."
        },
        {
          "id": "sent-016",
          "text": "Tiene paredes de roca muy altas.",
          "translationRu": "У неё очень высокие каменные стены."
        },
        {
          "id": "sent-017",
          "text": "La llaman la Montaña de la Luna.",
          "translationRu": "Её называют Горой Луны."
        }
      ]
    }
  ]
}
