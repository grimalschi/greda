{
  "schemaVersion": "1.0",
  "workId": "tarrano-the-conqueror",
  "level": "a1",
  "chapter": {
    "id": "chapter-001",
    "number": 1,
    "title": "Capítulo 1"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Yo trabajo para un periódico en Nueva York.",
          "translationRu": "Я работаю в газете в Нью-Йорке."
        },
        {
          "id": "sent-002",
          "text": "El año es 2430.",
          "translationRu": "Год — 2430."
        },
        {
          "id": "sent-003",
          "text": "Hoy hay un evento grande en el parque.",
          "translationRu": "Сегодня в парке большое событие."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "El Presidente habla a mucha gente.",
          "translationRu": "Президент говорит перед большой толпой."
        },
        {
          "id": "sent-005",
          "text": "Hay ciento cincuenta mil personas en el parque.",
          "translationRu": "В парке сто пятьдесят тысяч человек."
        },
        {
          "id": "sent-006",
          "text": "Yo estoy cerca del Presidente.",
          "translationRu": "Я стою рядом с Президентом."
        },
        {
          "id": "sent-007",
          "text": "Un hombre de Venus está a mi lado.",
          "translationRu": "Рядом со мной стоит человек с Венеры."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-008",
          "text": "De repente, el Presidente cae.",
          "translationRu": "Внезапно Президент падает."
        },
        {
          "id": "sent-009",
          "text": "Hay sangre en su camisa blanca.",
          "translationRu": "На его белой рубашке — кровь."
        },
        {
          "id": "sent-010",
          "text": "La gente grita con horror.",
          "translationRu": "Люди кричат в ужасе."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-011",
          "text": "Yo pienso: «El hombre de Venus lo mató».",
          "translationRu": "Я думаю: «Человек с Венеры убил его»."
        },
        {
          "id": "sent-012",
          "text": "Voy a mi oficina y trabajo toda la noche.",
          "translationRu": "Я иду в офис и работаю всю ночь."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Esta noche pasan cosas terribles en todo el mundo.",
          "translationRu": "Этой ночью по всему миру происходят страшные вещи."
        },
        {
          "id": "sent-014",
          "text": "El líder de Mongolia también muere.",
          "translationRu": "Лидер Монголии тоже умирает."
        },
        {
          "id": "sent-015",
          "text": "El líder de África muere también.",
          "translationRu": "Лидер Африки тоже умирает."
        },
        {
          "id": "sent-016",
          "text": "Alguien mata a los líderes de la Tierra al mismo tiempo.",
          "translationRu": "Кто-то убивает лидеров Земли одновременно."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-017",
          "text": "Llega un mensaje de Venus.",
          "translationRu": "Приходит сообщение с Венеры."
        },
        {
          "id": "sent-018",
          "text": "El mensaje dice: «¡Peligro! ¡Cuidado con Tarrano!»",
          "translationRu": "В сообщении написано: «Опасность! Берегитесь Таррано!»"
        },
        {
          "id": "sent-019",
          "text": "Después la comunicación con Venus termina.",
          "translationRu": "После этого связь с Венерой обрывается."
        }
      ]
    }
  ]
}
