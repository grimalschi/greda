{
  "schemaVersion": "1.0",
  "workId": "a-tale-of-two-cities",
  "level": "a2",
  "chapter": {
    "id": "chapter-001",
    "number": 1,
    "title": "Los tiempos turbulentos"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Era el mejor de los tiempos, era el peor de los tiempos.",
          "translationRu": "Это были лучшие времена, это были худшие времена."
        },
        {
          "id": "sent-002",
          "text": "En el año 1775, el mundo estaba lleno de cambios.",
          "translationRu": "В 1775 году мир был полон перемен."
        },
        {
          "id": "sent-003",
          "text": "En Inglaterra y en Francia, las personas tenían miedo.",
          "translationRu": "В Англии и во Франции люди боялись."
        },
        {
          "id": "sent-004",
          "text": "Los bandidos atacaban las carreteras.",
          "translationRu": "Бандиты нападали на дороги."
        },
        {
          "id": "sent-005",
          "text": "Las ciudades no eran seguras.",
          "translationRu": "Города были небезопасны."
        },
        {
          "id": "sent-006",
          "text": "En Francia, los pobres sufrían mucho.",
          "translationRu": "Во Франции бедные люди сильно страдали."
        },
        {
          "id": "sent-007",
          "text": "El hambre era un problema grave.",
          "translationRu": "Голод был серьёзной проблемой."
        },
        {
          "id": "sent-008",
          "text": "Los nobles no querían ayudar a los pobres.",
          "translationRu": "Дворяне не хотели помогать бедным."
        },
        {
          "id": "sent-009",
          "text": "Las personas sentían rabia en el corazón.",
          "translationRu": "Люди чувствовали гнев в сердце."
        },
        {
          "id": "sent-010",
          "text": "Pronto, todo iba a cambiar.",
          "translationRu": "Вскоре всё должно было измениться."
        },
        {
          "id": "sent-011",
          "text": "El futuro era muy oscuro.",
          "translationRu": "Будущее было очень тёмным."
        },
        {
          "id": "sent-012",
          "text": "Nadie sabía lo que iba a pasar.",
          "translationRu": "Никто не знал, что произойдёт."
        },
        {
          "id": "sent-013",
          "text": "Las noticias de París eran alarmantes.",
          "translationRu": "Новости из Парижа были тревожными."
        },
        {
          "id": "sent-014",
          "text": "Una tormenta grande se acercaba.",
          "translationRu": "Большая буря приближалась."
        },
        {
          "id": "sent-015",
          "text": "Este es el comienzo de una historia de dos ciudades.",
          "translationRu": "Это начало истории двух городов."
        }
      ]
    }
  ]
}
