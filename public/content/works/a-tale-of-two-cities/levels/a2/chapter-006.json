{
  "schemaVersion": "1.0",
  "workId": "a-tale-of-two-cities",
  "level": "a2",
  "chapter": {
    "id": "chapter-006",
    "number": 6,
    "title": "La revolución"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "En París, la revolución comenzó en 1789.",
          "translationRu": "В Париже революция началась в 1789 году."
        },
        {
          "id": "sent-002",
          "text": "El pueblo estaba furioso.",
          "translationRu": "Люди были в ярости."
        },
        {
          "id": "sent-003",
          "text": "Atacaron la Bastilla, la prisión más terrible.",
          "translationRu": "Они атаковали Бастилию, самую страшную тюрьму."
        },
        {
          "id": "sent-004",
          "text": "Los ciudadanos querían libertad.",
          "translationRu": "Граждане хотели свободы."
        },
        {
          "id": "sent-005",
          "text": "Monsieur Defarge fue a la Bastilla.",
          "translationRu": "Мсье Дефарж пошёл к Бастилии."
        },
        {
          "id": "sent-006",
          "text": "Encontró unos papeles en la prisión.",
          "translationRu": "Он нашёл бумаги в тюрьме."
        },
        {
          "id": "sent-007",
          "text": "Los papeles contenían un secreto terrible.",
          "translationRu": "Бумаги содержали ужасный секрет."
        },
        {
          "id": "sent-008",
          "text": "Era una carta del doctor Manette.",
          "translationRu": "Это было письмо доктора Манетта."
        },
        {
          "id": "sent-009",
          "text": "En la carta, el doctor denunciaba a los hermanos Evrémonde.",
          "translationRu": "В письме доктор обвинял братьев Эвремон."
        },
        {
          "id": "sent-010",
          "text": "Los hermanos lo habían metido en la prisión.",
          "translationRu": "Братья заключили его в тюрьму."
        },
        {
          "id": "sent-011",
          "text": "Charles Darnay era el sobrino de los hermanos.",
          "translationRu": "Чарльз Дарней был племянником братьев."
        },
        {
          "id": "sent-012",
          "text": "Los revolucionarios querían venganza.",
          "translationRu": "Революционеры хотели мести."
        },
        {
          "id": "sent-013",
          "text": "Madame Defarge era la más peligrosa.",
          "translationRu": "Мадам Дефарж была самой опасной."
        },
        {
          "id": "sent-014",
          "text": "Ella guardaba una lista de los nombres de sus enemigos.",
          "translationRu": "Она хранила список имён своих врагов."
        },
        {
          "id": "sent-015",
          "text": "El nombre de Darnay estaba en la lista.",
          "translationRu": "Имя Дарнея было в списке."
        },
        {
          "id": "sent-016",
          "text": "Todos estaban en peligro ahora.",
          "translationRu": "Все теперь были в опасности."
        }
      ]
    }
  ]
}
