{
  "schemaVersion": "1.0",
  "workId": "the-skylark-of-space",
  "level": "a1",
  "chapter": {"id": "chapter-008", "number": 8, "title": "Capítulo 8"},
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {"id": "sent-001", "text": "Seaton habla con Nalboon muy fuerte.", "translationRu": "Ситон говорит с Налбуном очень твёрдо."},
        {"id": "sent-002", "text": "Dice: «No somos enemigos, somos libres.»", "translationRu": "Он говорит: «Мы не враги, мы свободны»."},
        {"id": "sent-003", "text": "El grupo camina hacia el Skylark.", "translationRu": "Группа идёт к «Скайларку»."}
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {"id": "sent-004", "text": "Los guardias de Nalboon los detienen.", "translationRu": "Охранники Налбуна останавливают их."},
        {"id": "sent-005", "text": "Dunark ayuda a Seaton.", "translationRu": "Дунарк помогает Ситону."},
        {"id": "sent-006", "text": "Dunark usa una pistola eléctrica silenciosa.", "translationRu": "Дунарк использует тихий электрический пистолет."},
        {"id": "sent-007", "text": "Seaton y DuQuesne disparan a muchos soldados.", "translationRu": "Ситон и ДюКень стреляют во многих солдат."}
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {"id": "sent-008", "text": "El Skylark escapa del palacio de Nalboon.", "translationRu": "«Скайларк» вырывается из дворца Налбуна."},
        {"id": "sent-009", "text": "Vuelan al país de Kondal.", "translationRu": "Они летят в страну Кондал."},
        {"id": "sent-010", "text": "Kondal es el país amigo de Dunark.", "translationRu": "Кондал — дружественная страна Дунарка."}
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {"id": "sent-011", "text": "El Emperador Roban los recibe con alegría.", "translationRu": "Император Робан встречает их с радостью."},
        {"id": "sent-012", "text": "El Skylark se repara con un metal muy fuerte.", "translationRu": "«Скайларк» восстанавливают из очень прочного металла."},
        {"id": "sent-013", "text": "El metal se llama arenak.", "translationRu": "Металл называется аренак."}
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {"id": "sent-014", "text": "Seaton y Dorothy se casan.", "translationRu": "Ситон и Дороти женятся."},
        {"id": "sent-015", "text": "Crane y Margaret también se casan.", "translationRu": "Крэйн и Маргарет тоже женятся."},
        {"id": "sent-016", "text": "Es una ceremonia bonita en otro mundo.", "translationRu": "Это красивая церемония на другом мире."},
        {"id": "sent-017", "text": "Todos están muy felices.", "translationRu": "Все очень счастливы."}
      ]
    }
  ]
}
