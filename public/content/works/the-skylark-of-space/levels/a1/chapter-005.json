{
  "schemaVersion": "1.0",
  "workId": "the-skylark-of-space",
  "level": "a1",
  "chapter": {"id": "chapter-005", "number": 5, "title": "Capítulo 5"},
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {"id": "sent-001", "text": "DuQuesne trabaja para volver a la Tierra.", "translationRu": "ДюКень работает, чтобы вернуться на Землю."},
        {"id": "sent-002", "text": "Él es tranquilo y fuerte.", "translationRu": "Он спокойный и сильный."},
        {"id": "sent-003", "text": "Dice: «Vamos a volver a casa.»", "translationRu": "Он говорит: «Мы вернёмся домой»."}
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {"id": "sent-004", "text": "Dorothy y Margaret tienen miedo.", "translationRu": "Дороти и Маргарет боятся."},
        {"id": "sent-005", "text": "Margaret cuenta su historia a Dorothy.", "translationRu": "Маргарет рассказывает Дороти свою историю."},
        {"id": "sent-006", "text": "Ella trabaja para la compañía de acero.", "translationRu": "Она работала на сталелитейную компанию."},
        {"id": "sent-007", "text": "Ahora ella también es prisionera.", "translationRu": "Теперь она тоже пленница."}
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {"id": "sent-008", "text": "Dorothy encuentra dos pistolas.", "translationRu": "Дороти находит два пистолета."},
        {"id": "sent-009", "text": "Están en el abrigo de Perkins.", "translationRu": "Они в пальто Перкинса."},
        {"id": "sent-010", "text": "Ella da una pistola a Margaret.", "translationRu": "Она даёт один пистолет Маргарет."},
        {"id": "sent-011", "text": "Ahora las dos mujeres se sienten más seguras.", "translationRu": "Теперь обе женщины чувствуют себя в большей безопасности."}
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {"id": "sent-012", "text": "La nave vuela hacia una estrella muerta.", "translationRu": "Корабль летит к мёртвой звезде."},
        {"id": "sent-013", "text": "La estrella muerta atrae a la nave.", "translationRu": "Мёртвая звезда притягивает корабль."},
        {"id": "sent-014", "text": "La nave no puede escapar.", "translationRu": "Корабль не может сбежать."},
        {"id": "sent-015", "text": "Todo el cobre se acaba.", "translationRu": "Вся медь заканчивается."}
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {"id": "sent-016", "text": "DuQuesne no puede hacer nada más.", "translationRu": "ДюКень больше ничего не может сделать."},
        {"id": "sent-017", "text": "Todos esperan.", "translationRu": "Все ждут."},
        {"id": "sent-018", "text": "La situación es muy peligrosa.", "translationRu": "Ситуация очень опасна."}
      ]
    }
  ]
}
