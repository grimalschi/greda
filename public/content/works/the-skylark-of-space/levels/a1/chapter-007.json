{
  "schemaVersion": "1.0",
  "workId": "the-skylark-of-space",
  "level": "a1",
  "chapter": {"id": "chapter-007", "number": 7, "title": "Capítulo 7"},
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {"id": "sent-001", "text": "El Skylark llega a un planeta.", "translationRu": "«Скайларк» прилетает на планету."},
        {"id": "sent-002", "text": "El planeta tiene mucho cobre.", "translationRu": "На планете много меди."},
        {"id": "sent-003", "text": "Hay personas con piel verde.", "translationRu": "Там живут люди с зелёной кожей."}
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {"id": "sent-004", "text": "En el cielo hay una batalla.", "translationRu": "В небе идёт сражение."},
        {"id": "sent-005", "text": "Un monstruo grande ataca un avión verde.", "translationRu": "Большое чудовище атакует зелёный самолёт."},
        {"id": "sent-006", "text": "El monstruo se llama karlon.", "translationRu": "Чудовище называется карлон."},
        {"id": "sent-007", "text": "Seaton y Crane matan al monstruo.", "translationRu": "Ситон и Крэйн убивают чудовище."}
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {"id": "sent-008", "text": "Los verdes están muy agradecidos.", "translationRu": "Зелёные люди очень благодарны."},
        {"id": "sent-009", "text": "Su líder se llama Nalboon.", "translationRu": "Их вождь называется Налбун."},
        {"id": "sent-010", "text": "Nalboon invita a todos a su palacio.", "translationRu": "Налбун приглашает всех в свой дворец."}
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {"id": "sent-011", "text": "En el palacio hay catorce esclavos.", "translationRu": "Во дворце есть четырнадцать рабов."},
        {"id": "sent-012", "text": "Los esclavos tienen piel blanca.", "translationRu": "Кожа рабов светлая."},
        {"id": "sent-013", "text": "Uno de ellos es un príncipe.", "translationRu": "Один из них — принц."},
        {"id": "sent-014", "text": "Su nombre es Dunark.", "translationRu": "Его зовут Дунарк."}
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {"id": "sent-015", "text": "Dunark habla en secreto con Seaton.", "translationRu": "Дунарк тайно говорит с Ситоном."},
        {"id": "sent-016", "text": "Usa una máquina para enseñar el idioma.", "translationRu": "Он использует машину, чтобы обучить языку."},
        {"id": "sent-017", "text": "Dunark dice: «Nalboon quiere matarlos.»", "translationRu": "Дунарк говорит: «Налбун хочет вас убить»."},
        {"id": "sent-018", "text": "Seaton escucha con mucha atención.", "translationRu": "Ситон слушает с большим вниманием."}
      ]
    }
  ]
}
