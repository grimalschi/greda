{
  "schemaVersion": "1.0",
  "workId": "the-skylark-of-space",
  "level": "a1",
  "chapter": {"id": "chapter-004", "number": 4, "title": "Capítulo 4"},
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {"id": "sent-001", "text": "DuQuesne tiene un plan malo.", "translationRu": "У ДюКеня есть злой план."},
        {"id": "sent-002", "text": "Él construye una nave espacial pequeña.", "translationRu": "Он строит небольшой космический корабль."},
        {"id": "sent-003", "text": "La nave tiene paredes de cobre.", "translationRu": "У корабля медные стенки."}
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {"id": "sent-004", "text": "DuQuesne rapta a Dorothy.", "translationRu": "ДюКень похищает Дороти."},
        {"id": "sent-005", "text": "También hay una mujer más en la nave.", "translationRu": "В корабле есть ещё одна женщина."},
        {"id": "sent-006", "text": "Su nombre es Margaret Spencer.", "translationRu": "Её зовут Маргарет Спенсер."},
        {"id": "sent-007", "text": "Ella es prisionera de la compañía de acero.", "translationRu": "Она — пленница сталелитейной компании."}
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {"id": "sent-008", "text": "Hay un hombre más en la nave.", "translationRu": "В корабле есть ещё один мужчина."},
        {"id": "sent-009", "text": "Su nombre es Perkins.", "translationRu": "Его зовут Перкинс."},
        {"id": "sent-010", "text": "Dorothy lo patea muy fuerte.", "translationRu": "Дороти очень сильно ударяет его ногой."},
        {"id": "sent-011", "text": "Perkins cae sobre los controles.", "translationRu": "Перкинс падает на пульт управления."}
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {"id": "sent-012", "text": "La nave sube muy rápido.", "translationRu": "Корабль очень быстро взлетает."},
        {"id": "sent-013", "text": "Nadie puede detenerla.", "translationRu": "Никто не может её остановить."},
        {"id": "sent-014", "text": "La nave vuela muy lejos al espacio.", "translationRu": "Корабль улетает очень далеко в космос."}
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {"id": "sent-015", "text": "Todos pierden el conocimiento.", "translationRu": "Все теряют сознание."},
        {"id": "sent-016", "text": "Están inconscientes dos días.", "translationRu": "Они без сознания два дня."},
        {"id": "sent-017", "text": "DuQuesne se despierta primero.", "translationRu": "ДюКень просыпается первым."},
        {"id": "sent-018", "text": "Intenta controlar la nave.", "translationRu": "Он пытается управлять кораблём."}
      ]
    }
  ]
}
