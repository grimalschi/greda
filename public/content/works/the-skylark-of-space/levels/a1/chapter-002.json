{
  "schemaVersion": "1.0",
  "workId": "the-skylark-of-space",
  "level": "a1",
  "chapter": {"id": "chapter-002", "number": 2, "title": "Capítulo 2"},
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {"id": "sent-001", "text": "DuQuesne habla con Brookings.", "translationRu": "ДюКень разговаривает с Брукингсом."},
        {"id": "sent-002", "text": "Brookings es el jefe de la compañía de acero.", "translationRu": "Брукингс — глава сталелитейной компании."},
        {"id": "sent-003", "text": "Ellos quieren robar el descubrimiento de Seaton.", "translationRu": "Они хотят украсть открытие Ситона."}
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {"id": "sent-004", "text": "La compañía envía a su propio químico a trabajar con la solución.", "translationRu": "Компания посылает своего химика работать с раствором."},
        {"id": "sent-005", "text": "El químico no sabe usar la solución bien.", "translationRu": "Химик не умеет правильно пользоваться раствором."},
        {"id": "sent-006", "text": "Hay una explosión muy grande.", "translationRu": "Происходит очень большой взрыв."},
        {"id": "sent-007", "text": "El pueblo entero desaparece.", "translationRu": "Целый городок исчезает."}
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {"id": "sent-008", "text": "DuQuesne habla de nuevo con Brookings.", "translationRu": "ДюКень снова разговаривает с Брукингсом."},
        {"id": "sent-009", "text": "Ahora pide más dinero.", "translationRu": "Теперь он просит больше денег."},
        {"id": "sent-010", "text": "Brookings acepta.", "translationRu": "Брукингс соглашается."}
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {"id": "sent-011", "text": "Seaton y Crane trabajan mucho.", "translationRu": "Ситон и Крэйн много работают."},
        {"id": "sent-012", "text": "Hacen un modelo pequeño de su invento.", "translationRu": "Они делают маленькую модель своего изобретения."},
        {"id": "sent-013", "text": "Seaton vuela con el modelo.", "translationRu": "Ситон летит на модели."},
        {"id": "sent-014", "text": "El modelo funciona bien.", "translationRu": "Модель работает хорошо."}
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {"id": "sent-015", "text": "Una noche, DuQuesne ataca la casa de Crane.", "translationRu": "Однажды ночью ДюКень нападает на дом Крэйна."},
        {"id": "sent-016", "text": "Hay dos guardias en la puerta.", "translationRu": "У двери стоят два охранника."},
        {"id": "sent-017", "text": "DuQuesne los dispara.", "translationRu": "ДюКень стреляет в них."},
        {"id": "sent-018", "text": "También hiere al criado Shiro.", "translationRu": "Он также ранит слугу Широ."},
        {"id": "sent-019", "text": "DuQuesne roba los planes de Seaton y Crane.", "translationRu": "ДюКень крадёт планы Ситона и Крэйна."}
      ]
    }
  ]
}
