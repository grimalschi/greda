{
  "schemaVersion": "1.0",
  "workId": "in-the-abyss",
  "level": "a1",
  "chapter": {
    "id": "chapter-001",
    "number": 1,
    "title": "En el abismo"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Elstead es un científico.",
          "translationRu": "Элстед — учёный."
        },
        {
          "id": "sent-002",
          "text": "Él quiere ir al fondo del mar.",
          "translationRu": "Он хочет спуститься на дно моря."
        },
        {
          "id": "sent-003",
          "text": "Él hace una esfera de metal.",
          "translationRu": "Он делает стальную сферу."
        },
        {
          "id": "sent-004",
          "text": "La esfera es muy fuerte.",
          "translationRu": "Сфера очень прочная."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-005",
          "text": "Un barco lleva la esfera al océano.",
          "translationRu": "Корабль везёт сферу в океан."
        },
        {
          "id": "sent-006",
          "text": "Elstead entra en la esfera.",
          "translationRu": "Элстед входит в сферу."
        },
        {
          "id": "sent-007",
          "text": "Los marineros bajan la esfera al agua.",
          "translationRu": "Моряки опускают сферу в воду."
        },
        {
          "id": "sent-008",
          "text": "La esfera cae hacia abajo.",
          "translationRu": "Сфера опускается вниз."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-009",
          "text": "Hay mucha oscuridad en el agua.",
          "translationRu": "В воде очень темно."
        },
        {
          "id": "sent-010",
          "text": "Elstead ve animales pequeños con luz.",
          "translationRu": "Элстед видит маленьких светящихся животных."
        },
        {
          "id": "sent-011",
          "text": "La esfera llega al fondo del mar.",
          "translationRu": "Сфера достигает дна моря."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Elstead ve criaturas en el fondo.",
          "translationRu": "Элстед видит существ на дне."
        },
        {
          "id": "sent-013",
          "text": "Las criaturas tienen dos piernas.",
          "translationRu": "У существ две ноги."
        },
        {
          "id": "sent-014",
          "text": "Sus ojos son muy grandes.",
          "translationRu": "Их глаза очень большие."
        },
        {
          "id": "sent-015",
          "text": "Los ojos brillan en la oscuridad.",
          "translationRu": "Глаза светятся в темноте."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Las criaturas ven la esfera.",
          "translationRu": "Существа видят сферу."
        },
        {
          "id": "sent-017",
          "text": "Ellas toman la esfera y la llevan.",
          "translationRu": "Они берут сферу и несут её."
        },
        {
          "id": "sent-018",
          "text": "Hay una ciudad en el fondo del mar.",
          "translationRu": "На дне моря есть город."
        },
        {
          "id": "sent-019",
          "text": "La ciudad tiene calles y casas de piedra.",
          "translationRu": "В городе есть улицы и каменные дома."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-020",
          "text": "Las criaturas ponen la esfera en la plaza.",
          "translationRu": "Существа ставят сферу на площади."
        },
        {
          "id": "sent-021",
          "text": "Hay una gran piedra con luz dorada.",
          "translationRu": "Там есть большой камень с золотым светом."
        },
        {
          "id": "sent-022",
          "text": "Las criaturas hacen movimientos lentos.",
          "translationRu": "Существа делают медленные движения."
        },
        {
          "id": "sent-023",
          "text": "Elstead piensa: ellas creen que él es un dios.",
          "translationRu": "Элстед думает: они считают его богом."
        }
      ]
    },
    {
      "id": "para-007",
      "sentences": [
        {
          "id": "sent-024",
          "text": "La esfera empieza a subir sola.",
          "translationRu": "Сфера сама начинает подниматься."
        },
        {
          "id": "sent-025",
          "text": "Elstead sube al agua y llega al barco.",
          "translationRu": "Элстед всплывает и добирается до корабля."
        },
        {
          "id": "sent-026",
          "text": "Él cuenta su historia a los marineros.",
          "translationRu": "Он рассказывает морякам свою историю."
        },
        {
          "id": "sent-027",
          "text": "Muchas personas no creen su historia.",
          "translationRu": "Многие люди не верят его рассказу."
        }
      ]
    },
    {
      "id": "para-008",
      "sentences": [
        {
          "id": "sent-028",
          "text": "Elstead quiere bajar otra vez.",
          "translationRu": "Элстед хочет спуститься снова."
        },
        {
          "id": "sent-029",
          "text": "Él prepara la esfera de nuevo.",
          "translationRu": "Он снова готовит сферу."
        },
        {
          "id": "sent-030",
          "text": "La esfera baja al mar otra vez.",
          "translationRu": "Сфера снова уходит в море."
        },
        {
          "id": "sent-031",
          "text": "Los marineros esperan mucho tiempo.",
          "translationRu": "Моряки долго ждут."
        },
        {
          "id": "sent-032",
          "text": "Pero la esfera no vuelve.",
          "translationRu": "Но сфера не возвращается."
        },
        {
          "id": "sent-033",
          "text": "Elstead no vuelve nunca más.",
          "translationRu": "Элстед не возвращается никогда."
        }
      ]
    }
  ]
}
