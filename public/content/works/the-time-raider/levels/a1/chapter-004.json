{
  "schemaVersion": "1.0",
  "workId": "the-time-raider",
  "level": "a1",
  "chapter": {
    "id": "chapter-004",
    "number": 4,
    "title": "Capítulo 4"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Los soldados nos ponen en una celda.",
          "translationRu": "Солдаты помещают нас в камеру."
        },
        {
          "id": "sent-002",
          "text": "Hay muchos hombres en la celda.",
          "translationRu": "В камере много людей."
        },
        {
          "id": "sent-003",
          "text": "Estos hombres son de tiempos diferentes.",
          "translationRu": "Эти люди из разных эпох."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Los kanlars son los amos de la ciudad.",
          "translationRu": "Канлары — хозяева города."
        },
        {
          "id": "sent-005",
          "text": "Ellos tienen pelo rubio.",
          "translationRu": "У них светлые волосы."
        },
        {
          "id": "sent-006",
          "text": "Los kanlars usan a los hombres para pelear.",
          "translationRu": "Канлары используют людей для боёв."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Yo peleo con una espada.",
          "translationRu": "Я сражаюсь со шпагой."
        },
        {
          "id": "sent-008",
          "text": "Gano el combate.",
          "translationRu": "Я выигрываю поединок."
        },
        {
          "id": "sent-009",
          "text": "Denham también gana.",
          "translationRu": "Денем тоже выигрывает."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Debajo de la ciudad hay una gran cueva.",
          "translationRu": "Под городом находится большая пещера."
        },
        {
          "id": "sent-011",
          "text": "En la cueva hay miles de hombres prisioneros.",
          "translationRu": "В пещере тысячи людей-пленников."
        },
        {
          "id": "sent-012",
          "text": "El Saqueador los trae de todos los tiempos.",
          "translationRu": "Похититель приносит их из всех эпох."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Lantin y yo bajamos a la cueva.",
          "translationRu": "Мы с Лантеном спускаемся в пещеру."
        },
        {
          "id": "sent-014",
          "text": "Encontramos a Denham y sus amigos.",
          "translationRu": "Мы встречаем Денема и его друзей."
        },
        {
          "id": "sent-015",
          "text": "Sus amigos son de Roma, de Francia y de México.",
          "translationRu": "Его друзья из Рима, Франции и Мексики."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Ellos tienen un plan para escapar.",
          "translationRu": "У них есть план побега."
        },
        {
          "id": "sent-017",
          "text": "Lantin y yo vamos a escapar primero.",
          "translationRu": "Мы с Лантеном сбежим первыми."
        },
        {
          "id": "sent-018",
          "text": "Después volvemos con ayuda.",
          "translationRu": "Потом мы вернёмся с помощью."
        }
      ]
    }
  ]
}
