{
  "schemaVersion": "1.0",
  "workId": "the-time-raider",
  "level": "a1",
  "chapter": {
    "id": "chapter-003",
    "number": 3,
    "title": "Capítulo 3"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Lantin quiere salvar a Cannell.",
          "translationRu": "Лантен хочет спасти Каннела."
        },
        {
          "id": "sent-002",
          "text": "Él estudia los papeles de Cannell.",
          "translationRu": "Он изучает записи Каннела."
        },
        {
          "id": "sent-003",
          "text": "Lantin construye un coche del tiempo.",
          "translationRu": "Лантен строит машину времени."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "El coche es un cilindro de metal.",
          "translationRu": "Машина — металлический цилиндр."
        },
        {
          "id": "sent-005",
          "text": "Lantin y yo entramos al coche.",
          "translationRu": "Мы с Лантеном входим в машину."
        },
        {
          "id": "sent-006",
          "text": "El coche sube al aire y va al futuro.",
          "translationRu": "Машина поднимается в воздух и летит в будущее."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "El sol se mueve muy rápido.",
          "translationRu": "Солнце движется очень быстро."
        },
        {
          "id": "sent-008",
          "text": "Los años pasan muy rápido también.",
          "translationRu": "Годы тоже проходят очень быстро."
        },
        {
          "id": "sent-009",
          "text": "Vemos mucho hielo en el norte.",
          "translationRu": "Мы видим много льда на севере."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Hay una ciudad grande en el futuro.",
          "translationRu": "В будущем есть большой город."
        },
        {
          "id": "sent-011",
          "text": "Los edificios de la ciudad son cilindros blancos.",
          "translationRu": "Здания этого города — белые цилиндры."
        },
        {
          "id": "sent-012",
          "text": "Hay una luz violeta en el edificio más grande.",
          "translationRu": "На самом большом здании есть фиолетовый свет."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Lantin y yo salimos del coche.",
          "translationRu": "Мы с Лантеном выходим из машины."
        },
        {
          "id": "sent-014",
          "text": "Unos soldados nos ven.",
          "translationRu": "Нас замечают солдаты."
        },
        {
          "id": "sent-015",
          "text": "Los soldados nos toman prisioneros.",
          "translationRu": "Солдаты берут нас в плен."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Los soldados nos llevan a la ciudad.",
          "translationRu": "Солдаты ведут нас в город."
        },
        {
          "id": "sent-017",
          "text": "Yo conozco a un hombre inglés que habla inglés.",
          "translationRu": "Я знакомлюсь с английским человеком, который говорит по-английски."
        },
        {
          "id": "sent-018",
          "text": "Su nombre es Denham.",
          "translationRu": "Его имя — Денем."
        }
      ]
    }
  ]
}
