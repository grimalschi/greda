{
  "schemaVersion": "1.0",
  "workId": "the-jewel-robbery-at-the-grand-metropolitan",
  "level": "a1",
  "chapter": {
    "id": "chapter-001",
    "number": 1,
    "title": "Furtul de perle de la Grand Metropolitan"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Eu și Poirot suntem la Brighton.",
          "translationRu": "Мы с Пуаро в Брайтоне.",
          "original": "Poirot and I are at Brighton."
        },
        {
          "id": "sent-002",
          "text": "Stăm la un hotel mare lângă mare.",
          "translationRu": "Мы остановились в большой гостинице у моря.",
          "original": "We are staying at a big hotel by the sea."
        },
        {
          "id": "sent-003",
          "text": "Hotelul se numește Grand Metropolitan.",
          "translationRu": "Гостиница называется «Гранд-Метрополитен».",
          "original": "The hotel is called the Grand Metropolitan."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Mâncăm la restaurant.",
          "translationRu": "Мы обедаем в ресторане.",
          "original": "We are eating in the restaurant."
        },
        {
          "id": "sent-005",
          "text": "Mulți oameni de aici sunt bogați.",
          "translationRu": "Многие здесь богаты.",
          "original": "Many people here are rich."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-006",
          "text": "La masa de lângă noi sunt doi oameni.",
          "translationRu": "За соседним столом сидят двое.",
          "original": "At the next table there are two people."
        },
        {
          "id": "sent-007",
          "text": "Sunt domnul și doamna Opalsen.",
          "translationRu": "Это мистер и миссис Опалсен.",
          "original": "They are Mr. and Mrs. Opalsen."
        },
        {
          "id": "sent-008",
          "text": "Ei sunt foarte bogați.",
          "translationRu": "Они очень богаты.",
          "original": "They are very rich."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-009",
          "text": "Doamna Opalsen are perle frumoase.",
          "translationRu": "У миссис Опалсен красивый жемчуг.",
          "original": "Mrs. Opalsen has beautiful pearls."
        },
        {
          "id": "sent-010",
          "text": "Perlele sunt foarte scumpe.",
          "translationRu": "Жемчуг очень дорогой.",
          "original": "The pearls are very expensive."
        },
        {
          "id": "sent-011",
          "text": "Ea este mândră de perle.",
          "translationRu": "Она гордится жемчугом.",
          "original": "She is proud of the pearls."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Vreau să vă arăt perlele, spune ea.",
          "translationRu": "«Я хочу показать вам жемчуг», — говорит она.",
          "original": "I want to show you the pearls, she says."
        },
        {
          "id": "sent-013",
          "text": "Sunt în camera mea. Le aduc acum.",
          "translationRu": "«Он у меня в номере. Сейчас принесу».",
          "original": "They are in my room. I will bring them now."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-014",
          "text": "Doamna Opalsen urcă în camera ei.",
          "translationRu": "Миссис Опалсен поднимается в свой номер.",
          "original": "Mrs. Opalsen goes up to her room."
        },
        {
          "id": "sent-015",
          "text": "Noi așteptăm jos.",
          "translationRu": "Мы ждём внизу.",
          "original": "We wait downstairs."
        }
      ]
    },
    {
      "id": "para-007",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Deodată auzim un strigăt.",
          "translationRu": "Вдруг мы слышим крик.",
          "original": "Suddenly we hear a cry."
        },
        {
          "id": "sent-017",
          "text": "Doamna Opalsen coboară repede.",
          "translationRu": "Миссис Опалсен быстро спускается.",
          "original": "Mrs. Opalsen comes down quickly."
        },
        {
          "id": "sent-018",
          "text": "Perlele mele au dispărut! strigă ea.",
          "translationRu": "«Мой жемчуг пропал!» — кричит она.",
          "original": "My pearls are gone! she cries."
        }
      ]
    },
    {
      "id": "para-008",
      "sentences": [
        {
          "id": "sent-019",
          "text": "Liniștiți-vă, doamnă, spune Poirot.",
          "translationRu": "«Успокойтесь, мадам», — говорит Пуаро.",
          "original": "Calm yourself, madame, says Poirot."
        },
        {
          "id": "sent-020",
          "text": "Eu vă voi ajuta. Mergem sus.",
          "translationRu": "«Я вам помогу. Идём наверх».",
          "original": "I will help you. Let us go up."
        }
      ]
    },
    {
      "id": "para-009",
      "sentences": [
        {
          "id": "sent-021",
          "text": "Intrăm în camera doamnei.",
          "translationRu": "Мы входим в номер дамы.",
          "original": "We go into the lady's room."
        },
        {
          "id": "sent-022",
          "text": "Perlele au stat într-o cutie.",
          "translationRu": "Жемчуг лежал в шкатулке.",
          "original": "The pearls were in a box."
        },
        {
          "id": "sent-023",
          "text": "Cutia a stat într-un sertar.",
          "translationRu": "Шкатулка стояла в ящике.",
          "original": "The box was in a drawer."
        },
        {
          "id": "sent-024",
          "text": "Acum cutia este goală.",
          "translationRu": "Теперь шкатулка пуста.",
          "original": "Now the box is empty."
        }
      ]
    },
    {
      "id": "para-010",
      "sentences": [
        {
          "id": "sent-025",
          "text": "În cameră este Célestine.",
          "translationRu": "В номере находится Селестина.",
          "original": "In the room is Célestine."
        },
        {
          "id": "sent-026",
          "text": "Ea este camerista doamnei.",
          "translationRu": "Она горничная дамы.",
          "original": "She is the lady's maid."
        },
        {
          "id": "sent-027",
          "text": "Ea plânge și are frică.",
          "translationRu": "Она плачет и боится.",
          "original": "She cries and is afraid."
        }
      ]
    },
    {
      "id": "para-011",
      "sentences": [
        {
          "id": "sent-028",
          "text": "Ai stat aici? întreabă Poirot.",
          "translationRu": "«Ты была здесь?» — спрашивает Пуаро.",
          "original": "Were you here? asks Poirot."
        },
        {
          "id": "sent-029",
          "text": "Da, dar am ieșit de două ori, spune ea.",
          "translationRu": "«Да, но я выходила дважды», — говорит она.",
          "original": "Yes, but I went out twice, she says."
        }
      ]
    },
    {
      "id": "para-012",
      "sentences": [
        {
          "id": "sent-030",
          "text": "O altă femeie a venit în cameră.",
          "translationRu": "В номер заходила другая женщина.",
          "original": "Another woman came into the room."
        },
        {
          "id": "sent-031",
          "text": "Ea este camerista hotelului.",
          "translationRu": "Это горничная отеля.",
          "original": "She is the hotel chambermaid."
        },
        {
          "id": "sent-032",
          "text": "Célestine spune că ea a luat perlele.",
          "translationRu": "Селестина говорит, что жемчуг взяла она.",
          "original": "Célestine says she took the pearls."
        }
      ]
    },
    {
      "id": "para-013",
      "sentences": [
        {
          "id": "sent-033",
          "text": "Nu am furat nimic! strigă camerista.",
          "translationRu": "«Я ничего не крала!» — кричит горничная.",
          "original": "I have not stolen anything! cries the chambermaid."
        },
        {
          "id": "sent-034",
          "text": "Cele două femei se ceartă.",
          "translationRu": "Обе женщины ссорятся.",
          "original": "The two women argue."
        }
      ]
    },
    {
      "id": "para-014",
      "sentences": [
        {
          "id": "sent-035",
          "text": "Vine poliția.",
          "translationRu": "Приезжает полиция.",
          "original": "The police come."
        },
        {
          "id": "sent-036",
          "text": "Caută peste tot în cameră.",
          "translationRu": "Они ищут по всему номеру.",
          "original": "They search everywhere in the room."
        },
        {
          "id": "sent-037",
          "text": "Caută și pe cele două femei.",
          "translationRu": "Они обыскивают и обеих женщин.",
          "original": "They search the two women too."
        },
        {
          "id": "sent-038",
          "text": "Dar nu găsesc perlele.",
          "translationRu": "Но жемчуг не находят.",
          "original": "But they do not find the pearls."
        }
      ]
    },
    {
      "id": "para-015",
      "sentences": [
        {
          "id": "sent-039",
          "text": "Poirot se uită la sertar.",
          "translationRu": "Пуаро разглядывает ящик.",
          "original": "Poirot looks at the drawer."
        },
        {
          "id": "sent-040",
          "text": "Sertarul este uns cu grăsime.",
          "translationRu": "Ящик смазан жиром.",
          "original": "The drawer is greasy."
        },
        {
          "id": "sent-041",
          "text": "Poirot zâmbește încet.",
          "translationRu": "Пуаро тихо улыбается.",
          "original": "Poirot smiles quietly."
        }
      ]
    },
    {
      "id": "para-016",
      "sentences": [
        {
          "id": "sent-042",
          "text": "Lângă cameră este o cameră goală.",
          "translationRu": "Рядом есть пустой номер.",
          "original": "Next to the room is an empty room."
        },
        {
          "id": "sent-043",
          "text": "Cele două camere au o ușă comună.",
          "translationRu": "У этих номеров есть общая дверь.",
          "original": "The two rooms have a door between them."
        },
        {
          "id": "sent-044",
          "text": "Poirot se uită la ușă.",
          "translationRu": "Пуаро смотрит на дверь.",
          "original": "Poirot looks at the door."
        }
      ]
    },
    {
      "id": "para-017",
      "sentences": [
        {
          "id": "sent-045",
          "text": "Apoi poliția găsește perle.",
          "translationRu": "Потом полиция находит жемчуг.",
          "original": "Then the police find pearls."
        },
        {
          "id": "sent-046",
          "text": "Perlele sunt în patul cameristei.",
          "translationRu": "Жемчуг — в постели горничной.",
          "original": "The pearls are in the chambermaid's bed."
        },
        {
          "id": "sent-047",
          "text": "Toți cred că ea este hoața.",
          "translationRu": "Все думают, что воровка — она.",
          "original": "Everyone thinks she is the thief."
        }
      ]
    },
    {
      "id": "para-018",
      "sentences": [
        {
          "id": "sent-048",
          "text": "Nu eu am pus perlele acolo! plânge ea.",
          "translationRu": "«Это не я положила туда жемчуг!» — плачет она.",
          "original": "I did not put the pearls there! she cries."
        },
        {
          "id": "sent-049",
          "text": "Dar nimeni nu o crede.",
          "translationRu": "Но ей никто не верит.",
          "original": "But no one believes her."
        }
      ]
    },
    {
      "id": "para-019",
      "sentences": [
        {
          "id": "sent-050",
          "text": "Poirot ia perlele și le privește.",
          "translationRu": "Пуаро берёт жемчуг и разглядывает его.",
          "original": "Poirot takes the pearls and looks at them."
        },
        {
          "id": "sent-051",
          "text": "Aceste perle sunt false, spune el.",
          "translationRu": "«Этот жемчуг поддельный», — говорит он.",
          "original": "These pearls are false, he says."
        },
        {
          "id": "sent-052",
          "text": "Sunt din sticlă, nu sunt adevărate.",
          "translationRu": "«Они из стекла, не настоящие».",
          "original": "They are made of glass, not real."
        }
      ]
    },
    {
      "id": "para-020",
      "sentences": [
        {
          "id": "sent-053",
          "text": "False? întreabă doamna Opalsen.",
          "translationRu": "«Поддельный?» — спрашивает миссис Опалсен.",
          "original": "False? asks Mrs. Opalsen."
        },
        {
          "id": "sent-054",
          "text": "Da, nu sunt perlele dumneavoastră.",
          "translationRu": "«Да, это не ваш жемчуг».",
          "original": "Yes, they are not your pearls."
        },
        {
          "id": "sent-055",
          "text": "Cineva le-a pus aici, spune Poirot.",
          "translationRu": "«Кто-то их сюда подложил», — говорит Пуаро.",
          "original": "Someone put them here, says Poirot."
        }
      ]
    },
    {
      "id": "para-021",
      "sentences": [
        {
          "id": "sent-056",
          "text": "Camerista nu este hoața.",
          "translationRu": "Горничная — не воровка.",
          "original": "The chambermaid is not the thief."
        },
        {
          "id": "sent-057",
          "text": "Cineva vrea s-o învinovățească.",
          "translationRu": "Кто-то хочет её оговорить.",
          "original": "Someone wants to blame her."
        },
        {
          "id": "sent-058",
          "text": "Perlele adevărate sunt deja departe.",
          "translationRu": "Настоящий жемчуг уже далеко.",
          "original": "The real pearls are already far away."
        }
      ]
    },
    {
      "id": "para-022",
      "sentences": [
        {
          "id": "sent-059",
          "text": "Acum Poirot explică totul.",
          "translationRu": "Теперь Пуаро всё объясняет.",
          "original": "Now Poirot explains everything."
        },
        {
          "id": "sent-060",
          "text": "Doi oameni au lucrat împreună.",
          "translationRu": "Двое работали вместе.",
          "original": "Two people worked together."
        },
        {
          "id": "sent-061",
          "text": "Camerista hotelului și un valet.",
          "translationRu": "Горничная отеля и слуга-камердинер.",
          "original": "The hotel chambermaid and a valet."
        },
        {
          "id": "sent-062",
          "text": "Ei sunt hoți de bijuterii.",
          "translationRu": "Они — воры драгоценностей.",
          "original": "They are jewel thieves."
        }
      ]
    },
    {
      "id": "para-023",
      "sentences": [
        {
          "id": "sent-063",
          "text": "Camerista a luat cutia din sertar.",
          "translationRu": "Горничная вынула шкатулку из ящика.",
          "original": "The chambermaid took the box from the drawer."
        },
        {
          "id": "sent-064",
          "text": "De aceea sertarul era uns.",
          "translationRu": "Поэтому ящик был смазан.",
          "original": "That is why the drawer was greasy."
        },
        {
          "id": "sent-065",
          "text": "Sertarul s-a deschis fără zgomot.",
          "translationRu": "Ящик открылся без шума.",
          "original": "The drawer opened without noise."
        }
      ]
    },
    {
      "id": "para-024",
      "sentences": [
        {
          "id": "sent-066",
          "text": "Ea a dat cutia valetului.",
          "translationRu": "Она передала шкатулку камердинеру.",
          "original": "She gave the box to the valet."
        },
        {
          "id": "sent-067",
          "text": "Valetul a așteptat în camera goală.",
          "translationRu": "Камердинер ждал в пустом номере.",
          "original": "The valet waited in the empty room."
        },
        {
          "id": "sent-068",
          "text": "El a luat perlele adevărate.",
          "translationRu": "Он забрал настоящий жемчуг.",
          "original": "He took the real pearls."
        }
      ]
    },
    {
      "id": "para-025",
      "sentences": [
        {
          "id": "sent-069",
          "text": "Apoi a pus cutia goală înapoi.",
          "translationRu": "Потом он вернул пустую шкатулку на место.",
          "original": "Then he put the empty box back."
        },
        {
          "id": "sent-070",
          "text": "Totul s-a făcut în câteva minute.",
          "translationRu": "Всё было сделано за несколько минут.",
          "original": "It was all done in a few minutes."
        }
      ]
    },
    {
      "id": "para-026",
      "sentences": [
        {
          "id": "sent-071",
          "text": "Perlele false au fost un truc.",
          "translationRu": "Поддельный жемчуг был уловкой.",
          "original": "The false pearls were a trick."
        },
        {
          "id": "sent-072",
          "text": "Hoții le-au pus în patul fetei.",
          "translationRu": "Воры подложили его в постель девушки.",
          "original": "The thieves put them in the girl's bed."
        },
        {
          "id": "sent-073",
          "text": "Așa poliția dă vina pe ea.",
          "translationRu": "Так полиция свалила бы вину на неё.",
          "original": "So the police would blame her."
        },
        {
          "id": "sent-074",
          "text": "Iar hoții adevărați scapă.",
          "translationRu": "А настоящие воры уйдут.",
          "original": "And the real thieves get away."
        }
      ]
    },
    {
      "id": "para-027",
      "sentences": [
        {
          "id": "sent-075",
          "text": "Dar Poirot are un plan.",
          "translationRu": "Но у Пуаро есть план.",
          "original": "But Poirot has a plan."
        },
        {
          "id": "sent-076",
          "text": "El le dă o carte celor doi.",
          "translationRu": "Он даёт обоим карточку.",
          "original": "He gives a card to the two of them."
        },
        {
          "id": "sent-077",
          "text": "Ei ating cartea cu degetele.",
          "translationRu": "Они трогают карточку пальцами.",
          "original": "They touch the card with their fingers."
        },
        {
          "id": "sent-078",
          "text": "Acum Poirot are amprentele lor.",
          "translationRu": "Теперь у Пуаро есть их отпечатки.",
          "original": "Now Poirot has their fingerprints."
        }
      ]
    },
    {
      "id": "para-028",
      "sentences": [
        {
          "id": "sent-079",
          "text": "Poirot dă amprentele poliției.",
          "translationRu": "Пуаро передаёт отпечатки полиции.",
          "original": "Poirot gives the fingerprints to the police."
        },
        {
          "id": "sent-080",
          "text": "Prietenul lui este inspectorul Japp.",
          "translationRu": "Его друг — инспектор Джепп.",
          "original": "His friend is Inspector Japp."
        },
        {
          "id": "sent-081",
          "text": "Japp cunoaște acești hoți.",
          "translationRu": "Джепп знает этих воров.",
          "original": "Japp knows these thieves."
        },
        {
          "id": "sent-082",
          "text": "Ei au mai furat și înainte.",
          "translationRu": "Они крали и раньше.",
          "original": "They have stolen before."
        }
      ]
    },
    {
      "id": "para-029",
      "sentences": [
        {
          "id": "sent-083",
          "text": "Poliția îi prinde pe cei doi hoți.",
          "translationRu": "Полиция ловит обоих воров.",
          "original": "The police catch the two thieves."
        },
        {
          "id": "sent-084",
          "text": "Ei aveau încă perlele adevărate.",
          "translationRu": "Настоящий жемчуг был ещё у них.",
          "original": "They still had the real pearls."
        },
        {
          "id": "sent-085",
          "text": "Doamna Opalsen le primește înapoi.",
          "translationRu": "Миссис Опалсен получает его назад.",
          "original": "Mrs. Opalsen gets them back."
        }
      ]
    },
    {
      "id": "para-030",
      "sentences": [
        {
          "id": "sent-086",
          "text": "Célestine nu este vinovată.",
          "translationRu": "Селестина не виновата.",
          "original": "Célestine is not guilty."
        },
        {
          "id": "sent-087",
          "text": "Nici camerista nu este vinovată.",
          "translationRu": "И горничная не виновата.",
          "original": "The chambermaid is not guilty either."
        },
        {
          "id": "sent-088",
          "text": "Toți îi mulțumesc lui Poirot.",
          "translationRu": "Все благодарят Пуаро.",
          "original": "Everyone thanks Poirot."
        }
      ]
    },
    {
      "id": "para-031",
      "sentences": [
        {
          "id": "sent-089",
          "text": "Cum ai știut? îl întreb eu.",
          "translationRu": "«Как ты понял?» — спрашиваю я.",
          "original": "How did you know? I ask him."
        },
        {
          "id": "sent-090",
          "text": "Perlele false mi-au spus adevărul.",
          "translationRu": "«Поддельный жемчуг сказал мне правду».",
          "original": "The false pearls told me the truth."
        },
        {
          "id": "sent-091",
          "text": "Un hoț adevărat nu lasă perle bune.",
          "translationRu": "«Настоящий вор не оставит хороший жемчуг».",
