{
  "schemaVersion": "1.0",
  "workId": "the-sea-girl",
  "level": "a1",
  "chapter": {
    "id": "chapter-007",
    "number": 7,
    "title": "Capítulo 7"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "La emperatriz Rhana es muy peligrosa.",
          "translationRu": "Императрица Рана очень опасна."
        },
        {
          "id": "sent-002",
          "text": "Ella quiere conquistar la Tierra.",
          "translationRu": "Она хочет завоевать Землю."
        },
        {
          "id": "sent-003",
          "text": "Rhana abre las compuertas del agua.",
          "translationRu": "Рана открывает ворота воды."
        },
        {
          "id": "sent-004",
          "text": "El agua del mar baja muy rápido.",
          "translationRu": "Уровень морской воды падает очень быстро."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-005",
          "text": "Los Gianes suben al mundo de la superficie.",
          "translationRu": "Гианы поднимаются на поверхность мира."
        },
        {
          "id": "sent-006",
          "text": "Llevan una enfermedad muy mala.",
          "translationRu": "Они несут очень опасную болезнь."
        },
        {
          "id": "sent-007",
          "text": "Rhana captura a Nereida y a mí.",
          "translationRu": "Рана захватывает Нереиду и меня."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-008",
          "text": "Rhana quiere que yo la ayude.",
          "translationRu": "Рана хочет, чтобы я ей помог."
        },
        {
          "id": "sent-009",
          "text": "Yo me hago amigo de ella.",
          "translationRu": "Я притворяюсь её другом."
        },
        {
          "id": "sent-010",
          "text": "Espero el momento de escapar.",
          "translationRu": "Я жду момента, чтобы сбежать."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-011",
          "text": "Rhana ataca un avión de paz.",
          "translationRu": "Рана нападает на мирный самолёт."
        },
        {
          "id": "sent-012",
          "text": "El avión cae al abismo.",
          "translationRu": "Самолёт падает в пропасть."
        },
        {
          "id": "sent-013",
          "text": "Nereida tiene un plan para salvar el mundo.",
          "translationRu": "У Нереиды есть план спасти мир."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-014",
          "text": "Nereida rompe el motor del aeronave.",
          "translationRu": "Нереида ломает двигатель воздушного судна."
        },
        {
          "id": "sent-015",
          "text": "El aeronave cae.",
          "translationRu": "Воздушное судно падает."
        },
        {
          "id": "sent-016",
          "text": "Yo agarro a Rhana para salvar a Nereida.",
          "translationRu": "Я хватаю Рану, чтобы спасти Нереиду."
        },
        {
          "id": "sent-017",
          "text": "Caemos juntos sobre las rocas.",
          "translationRu": "Мы вместе падаем на скалы."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-018",
          "text": "Polly y el doctor Plantet nos encuentran.",
          "translationRu": "Полли и доктор Планте находят нас."
        },
        {
          "id": "sent-019",
          "text": "Nereida y yo estamos vivos.",
          "translationRu": "Нереида и я живы."
        },
        {
          "id": "sent-020",
          "text": "Arturo y Tad llegan también.",
          "translationRu": "Артуро и Тад тоже приходят."
        },
        {
          "id": "sent-021",
          "text": "Arturo abraza a Nereida.",
          "translationRu": "Артуро обнимает Нереиду."
        }
      ]
    },
    {
      "id": "para-007",
      "sentences": [
        {
          "id": "sent-022",
          "text": "Los Middge destruyen a los Gianes.",
          "translationRu": "Миджи уничтожают гианов."
        },
        {
          "id": "sent-023",
          "text": "Después, los Middge desaparecen bajo la tierra.",
          "translationRu": "После этого миджи исчезают под землёй."
        },
        {
          "id": "sent-024",
          "text": "El mundo está seguro.",
          "translationRu": "Мир в безопасности."
        },
        {
          "id": "sent-025",
          "text": "Arturo y Nereida viven junto a un río.",
          "translationRu": "Артуро и Нереида живут у реки."
        },
        {
          "id": "sent-026",
          "text": "Polly y yo también somos felices.",
          "translationRu": "Полли и я тоже счастливы."
        }
      ]
    }
  ]
}
