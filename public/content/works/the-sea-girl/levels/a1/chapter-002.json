{
  "schemaVersion": "1.0",
  "workId": "the-sea-girl",
  "level": "a1",
  "chapter": {
    "id": "chapter-002",
    "number": 2,
    "title": "Capítulo 2"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Los barcos desaparecen en el Pacífico.",
          "translationRu": "Корабли исчезают в Тихом океане."
        },
        {
          "id": "sent-002",
          "text": "El agua del mar baja.",
          "translationRu": "Уровень воды в море падает."
        },
        {
          "id": "sent-003",
          "text": "Los puertos tienen menos agua.",
          "translationRu": "В портах становится меньше воды."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Arturo y yo vamos a casa del doctor Plantet.",
          "translationRu": "Мы с Артуро идём в дом доктора Планте."
        },
        {
          "id": "sent-005",
          "text": "Su hija Polly nos recibe en el aeropuerto.",
          "translationRu": "Его дочь Полли встречает нас в аэропорту."
        },
        {
          "id": "sent-006",
          "text": "Polly es pequeña y práctica.",
          "translationRu": "Полли маленькая и практичная."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "El doctor Plantet es un científico.",
          "translationRu": "Доктор Планте — учёный."
        },
        {
          "id": "sent-008",
          "text": "Él estudia el mar.",
          "translationRu": "Он изучает море."
        },
        {
          "id": "sent-009",
          "text": "Él tiene una cara seria.",
          "translationRu": "У него серьёзное лицо."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "El doctor nos habla del mar.",
          "translationRu": "Доктор рассказывает нам о море."
        },
        {
          "id": "sent-011",
          "text": "El agua del mar va bajo la tierra.",
          "translationRu": "Вода из моря уходит под землю."
        },
        {
          "id": "sent-012",
          "text": "La tierra tiene muchas cuevas dentro.",
          "translationRu": "В земле внутри много пещер."
        },
        {
          "id": "sent-013",
          "text": "El agua entra en estas cuevas.",
          "translationRu": "Вода входит в эти пещеры."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-014",
          "text": "Hay personas bajo el mar.",
          "translationRu": "Под морем живут люди."
        },
        {
          "id": "sent-015",
          "text": "Estas personas toman los barcos de comida.",
          "translationRu": "Эти люди забирают корабли с едой."
        },
        {
          "id": "sent-016",
          "text": "Ellos quieren conquistar nuestro mundo.",
          "translationRu": "Они хотят завоевать наш мир."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-017",
          "text": "Polly escucha las noticias.",
          "translationRu": "Полли слушает новости."
        },
        {
          "id": "sent-018",
          "text": "Una pescadora ve a una sirena en una isla.",
          "translationRu": "Рыбачка видит русалку на острове."
        },
        {
          "id": "sent-019",
          "text": "La sirena tiene pelo verde como algas.",
          "translationRu": "У русалки зелёные волосы как водоросли."
        }
      ]
    }
  ]
}
