{
  "schemaVersion": "1.0",
  "workId": "the-sea-girl",
  "level": "a1",
  "chapter": {
    "id": "chapter-004",
    "number": 4,
    "title": "Capítulo 4"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Arturo espera en una isla pequeña.",
          "translationRu": "Артуро ждёт на маленьком острове."
        },
        {
          "id": "sent-002",
          "text": "La noche es oscura y hay estrellas.",
          "translationRu": "Ночь тёмная, и видны звёзды."
        },
        {
          "id": "sent-003",
          "text": "Arturo toca el violín solo.",
          "translationRu": "Артуро играет на скрипке в одиночестве."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Una chica aparece entre las palmeras.",
          "translationRu": "Среди пальм появляется девушка."
        },
        {
          "id": "sent-005",
          "text": "Ella tiene pelo largo y ojos verdes.",
          "translationRu": "У неё длинные волосы и зелёные глаза."
        },
        {
          "id": "sent-006",
          "text": "Su ropa es verde como el mar.",
          "translationRu": "Её одежда зелёная, как море."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Arturo habla con la chica.",
          "translationRu": "Артуро разговаривает с девушкой."
        },
        {
          "id": "sent-008",
          "text": "Él la llama Nereida.",
          "translationRu": "Он называет её Нереидой."
        },
        {
          "id": "sent-009",
          "text": "Nereida tiene miedo al principio.",
          "translationRu": "Сначала Нереида боится."
        },
        {
          "id": "sent-010",
          "text": "Pero ella escucha la música y se queda.",
          "translationRu": "Но она слушает музыку и остаётся."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-011",
          "text": "Nereida nada muy bien en el mar.",
          "translationRu": "Нереида очень хорошо плавает в море."
        },
        {
          "id": "sent-012",
          "text": "Ella vive bajo el agua.",
          "translationRu": "Она живёт под водой."
        },
        {
          "id": "sent-013",
          "text": "Ella aprende a hablar con Arturo.",
          "translationRu": "Она учится разговаривать с Артуро."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-014",
          "text": "Nuestro barco llega a la isla.",
          "translationRu": "Наш корабль прибывает на остров."
        },
        {
          "id": "sent-015",
          "text": "Arturo y Nereida nadan hacia nosotros.",
          "translationRu": "Артуро и Нереида плывут к нам."
        },
        {
          "id": "sent-016",
          "text": "Subimos a Nereida al barco.",
          "translationRu": "Мы поднимаем Нереиду на корабль."
        },
        {
          "id": "sent-017",
          "text": "La luz del día la lastima los ojos.",
          "translationRu": "Дневной свет причиняет боль её глазам."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-018",
          "text": "Arturo protege a Nereida.",
          "translationRu": "Артуро защищает Нереиду."
        },
        {
          "id": "sent-019",
          "text": "Él es diferente ahora.",
          "translationRu": "Теперь он другой."
        },
        {
          "id": "sent-020",
          "text": "Arturo es serio y fuerte.",
          "translationRu": "Артуро серьёзен и силён."
        }
      ]
    }
  ]
}
