{
  "schemaVersion": "1.0",
  "workId": "the-sea-girl",
  "level": "a1",
  "chapter": {
    "id": "chapter-003",
    "number": 3,
    "title": "Capítulo 3"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "El doctor Plantet construye un barco pequeño.",
          "translationRu": "Доктор Планте строит маленький корабль."
        },
        {
          "id": "sent-002",
          "text": "El barco se llama El Delfín.",
          "translationRu": "Корабль называется «Дельфин»."
        },
        {
          "id": "sent-003",
          "text": "Este barco puede ir muy profundo en el mar.",
          "translationRu": "Этот корабль может опускаться очень глубоко в море."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Yo voy a navegar el barco.",
          "translationRu": "Я буду управлять кораблём."
        },
        {
          "id": "sent-005",
          "text": "Polly viene con nosotros.",
          "translationRu": "Полли едет с нами."
        },
        {
          "id": "sent-006",
          "text": "Arturo también quiere venir.",
          "translationRu": "Артуро тоже хочет поехать."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Un día, Arturo desaparece de su cuarto.",
          "translationRu": "Однажды Артуро исчезает из своей комнаты."
        },
        {
          "id": "sent-008",
          "text": "Deja una nota para su padre.",
          "translationRu": "Он оставляет записку для отца."
        },
        {
          "id": "sent-009",
          "text": "Escribe: «Cree en mí, padre.»",
          "translationRu": "Он пишет: «Верь в меня, отец»."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "El doctor Plantet está muy triste.",
          "translationRu": "Доктор Планте очень расстроен."
        },
        {
          "id": "sent-011",
          "text": "Pero él no para el viaje.",
          "translationRu": "Но он не останавливает путешествие."
        },
        {
          "id": "sent-012",
          "text": "El Delfín sale de noche al Pacífico.",
          "translationRu": "«Дельфин» выходит ночью в Тихий океан."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "El barco va muy profundo.",
          "translationRu": "Корабль уходит очень глубоко."
        },
        {
          "id": "sent-014",
          "text": "Vemos el fondo del mar.",
          "translationRu": "Мы видим дно моря."
        },
        {
          "id": "sent-015",
          "text": "Hay montañas y cuevas en el fondo.",
          "translationRu": "На дне есть горы и пещеры."
        },
        {
          "id": "sent-016",
          "text": "Todo es oscuro y misterioso.",
          "translationRu": "Всё темно и таинственно."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-017",
          "text": "Arturo nos llama por radio.",
          "translationRu": "Артуро звонит нам по радио."
        },
        {
          "id": "sent-018",
          "text": "Él dice: «¡Vengan rápido a mi isla!»",
          "translationRu": "Он говорит: «Скорее приезжайте на мой остров!»"
        },
        {
          "id": "sent-019",
          "text": "Vamos a la isla de Arturo.",
          "translationRu": "Мы едем на остров Артуро."
        }
      ]
    }
  ]
}
