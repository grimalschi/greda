{
  "schemaVersion": "1.0",
  "workId": "the-sea-girl",
  "level": "a1",
  "chapter": {
    "id": "chapter-005",
    "number": 5,
    "title": "Capítulo 5"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Arturo nos habla del enemigo.",
          "translationRu": "Артуро рассказывает нам о враге."
        },
        {
          "id": "sent-002",
          "text": "Los enemigos se llaman los Gianes.",
          "translationRu": "Враги называются гианами."
        },
        {
          "id": "sent-003",
          "text": "Ellos viven bajo el Pacífico.",
          "translationRu": "Они живут под Тихим океаном."
        },
        {
          "id": "sent-004",
          "text": "Quieren subir y tomar nuestro mundo.",
          "translationRu": "Они хотят подняться и захватить наш мир."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-005",
          "text": "Nereida es de otro pueblo.",
          "translationRu": "Нереида из другого народа."
        },
        {
          "id": "sent-006",
          "text": "Su pueblo se llama los Middge.",
          "translationRu": "Её народ называется миджами."
        },
        {
          "id": "sent-007",
          "text": "Los Middge son pequeños y blancos.",
          "translationRu": "Миджи маленькие и белокожие."
        },
        {
          "id": "sent-008",
          "text": "Los Gianes son grandes y grises.",
          "translationRu": "Гианы большие и серокожие."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-009",
          "text": "Vamos a buscar al enemigo bajo el mar.",
          "translationRu": "Мы отправляемся искать врага под водой."
        },
        {
          "id": "sent-010",
          "text": "Cerca de Maui, vemos luces en el fondo.",
          "translationRu": "Вблизи Мауи мы видим огни на дне."
        },
        {
          "id": "sent-011",
          "text": "Hay muchas máquinas grandes ahí.",
          "translationRu": "Там много больших машин."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Los Gianes suben con sus máquinas.",
          "translationRu": "Гианы поднимаются со своими машинами."
        },
        {
          "id": "sent-013",
          "text": "De repente, una luz nos atrapa.",
          "translationRu": "Вдруг свет захватывает нас."
        },
        {
          "id": "sent-014",
          "text": "La luz tira el barco hacia abajo.",
          "translationRu": "Свет тянет корабль вниз."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-015",
          "text": "El doctor lanza una bomba de luz.",
          "translationRu": "Доктор запускает световую бомбу."
        },
        {
          "id": "sent-016",
          "text": "La luz nos suelta.",
          "translationRu": "Свет нас отпускает."
        },
        {
          "id": "sent-017",
          "text": "Subimos rápido a la superficie.",
          "translationRu": "Мы быстро поднимаемся на поверхность."
        },
        {
          "id": "sent-018",
          "text": "¡Escapamos del peligro!",
          "translationRu": "Мы спасаемся от опасности!"
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-019",
          "text": "Esa noche, Arturo y Nereida saltan al agua.",
          "translationRu": "В ту ночь Артуро и Нереида прыгают в воду."
        },
        {
          "id": "sent-020",
          "text": "Ellos desaparecen bajo el mar.",
          "translationRu": "Они исчезают под водой."
        },
        {
          "id": "sent-021",
          "text": "No los vemos más por mucho tiempo.",
          "translationRu": "Мы долго их не видим."
        }
      ]
    }
  ]
}
