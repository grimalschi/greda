{
  "schemaVersion": "1.0",
  "workId": "the-mad-planet",
  "level": "a1",
  "chapter": {
    "id": "chapter-001",
    "number": 1,
    "title": "Capítulo 1"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Burl es un hombre joven.",
          "translationRu": "Бёрл — молодой человек."
        },
        {
          "id": "sent-002",
          "text": "Él vive en un mundo muy extraño.",
          "translationRu": "Он живёт в очень странном мире."
        },
        {
          "id": "sent-003",
          "text": "El suelo tiene hongos de muchos colores.",
          "translationRu": "На земле растут грибы самых разных цветов."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "El cielo está siempre gris y nublado.",
          "translationRu": "Небо всегда серое и облачное."
        },
        {
          "id": "sent-005",
          "text": "Burl nunca ve el sol.",
          "translationRu": "Бёрл никогда не видит солнца."
        },
        {
          "id": "sent-006",
          "text": "Los hongos son muy grandes, más altos que tres hombres.",
          "translationRu": "Грибы очень большие — выше трёх человек."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Burl lleva una ropa de ala de mariposa.",
          "translationRu": "Бёрл носит одежду из крыла бабочки."
        },
        {
          "id": "sent-008",
          "text": "Su piel es rosada y suave.",
          "translationRu": "Его кожа розовая и нежная."
        },
        {
          "id": "sent-009",
          "text": "Sus ojos son grandes y azules.",
          "translationRu": "Его глаза большие и голубые."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-010",
          "text": "Hace mucho tiempo, los hombres vivían bien.",
          "translationRu": "Давным-давно люди жили хорошо."
        },
        {
          "id": "sent-011",
          "text": "Había ciudades y máquinas.",
          "translationRu": "Были города и машины."
        },
        {
          "id": "sent-012",
          "text": "Pero la Tierra empezó a cambiar.",
          "translationRu": "Но Земля начала меняться."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-013",
          "text": "Un gas malo salió del suelo.",
          "translationRu": "Из земли начал выходить вредный газ."
        },
        {
          "id": "sent-014",
          "text": "El aire se hizo pesado y caliente.",
          "translationRu": "Воздух стал тяжёлым и горячим."
        },
        {
          "id": "sent-015",
          "text": "Los árboles murieron y los hongos crecieron.",
          "translationRu": "Деревья погибли, и выросли грибы."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-016",
          "text": "Los insectos crecieron mucho.",
          "translationRu": "Насекомые очень выросли."
        },
        {
          "id": "sent-017",
          "text": "Hay abejas tan grandes como Burl.",
          "translationRu": "Есть пчёлы такого же размера, как Бёрл."
        },
        {
          "id": "sent-018",
          "text": "Las arañas son peligrosas y grandes.",
          "translationRu": "Пауки опасные и большие."
        }
      ]
    }
  ]
}
