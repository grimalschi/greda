{
  "schemaVersion": "1.0",
  "workId": "the-mad-planet",
  "level": "a1",
  "chapter": {
    "id": "chapter-003",
    "number": 3,
    "title": "Capítulo 3"
  },
  "paragraphs": [
    {
      "id": "para-001",
      "sentences": [
        {
          "id": "sent-001",
          "text": "Burl quiere volver con Saya.",
          "translationRu": "Бёрл хочет вернуться к Сайе."
        },
        {
          "id": "sent-002",
          "text": "Él camina junto al río.",
          "translationRu": "Он идёт вдоль реки."
        },
        {
          "id": "sent-003",
          "text": "De repente oye un sonido muy fuerte.",
          "translationRu": "Вдруг он слышит очень громкий звук."
        }
      ]
    },
    {
      "id": "para-002",
      "sentences": [
        {
          "id": "sent-004",
          "text": "Son hormigas. Muchas, muchas hormigas.",
          "translationRu": "Это муравьи. Очень много муравьёв."
        },
        {
          "id": "sent-005",
          "text": "Las hormigas son grandes, de treinta centímetros.",
          "translationRu": "Муравьи большие — около тридцати сантиметров."
        },
        {
          "id": "sent-006",
          "text": "Ellas comen todo lo que encuentran.",
          "translationRu": "Они едят всё, что встречают."
        }
      ]
    },
    {
      "id": "para-003",
      "sentences": [
        {
          "id": "sent-007",
          "text": "Burl tiene miedo y corre.",
          "translationRu": "Бёрл пугается и бежит."
        },
        {
          "id": "sent-008",
          "text": "Las hormigas vienen detrás de él.",
          "translationRu": "Муравьи бегут следом."
        }
      ]
    },
    {
      "id": "para-004",
      "sentences": [
        {
          "id": "sent-009",
          "text": "Burl sube a unas colinas de color morado.",
          "translationRu": "Бёрл взбирается на фиолетовые холмы."
        },
        {
          "id": "sent-010",
          "text": "Las colinas son hongos grandes.",
          "translationRu": "Холмы — это большие грибы."
        },
        {
          "id": "sent-011",
          "text": "Los hongos están muy calientes dentro.",
          "translationRu": "Внутри грибов очень жарко."
        }
      ]
    },
    {
      "id": "para-005",
      "sentences": [
        {
          "id": "sent-012",
          "text": "Hay fuego dentro de las colinas.",
          "translationRu": "Внутри холмов есть огонь."
        },
        {
          "id": "sent-013",
          "text": "Las hormigas entran y mueren en el fuego.",
          "translationRu": "Муравьи заходят и погибают в огне."
        },
        {
          "id": "sent-014",
          "text": "Burl está seguro.",
          "translationRu": "Бёрл в безопасности."
        }
      ]
    },
    {
      "id": "para-006",
      "sentences": [
        {
          "id": "sent-015",
          "text": "Por la noche, Burl ve el fuego por primera vez.",
          "translationRu": "Ночью Бёрл впервые видит огонь."
        },
        {
          "id": "sent-016",
          "text": "Las mariposas grandes vuelan hacia el fuego.",
          "translationRu": "Огромные бабочки летят на огонь."
        },
        {
          "id": "sent-017",
          "text": "Por la mañana, Burl encuentra una polilla muerta.",
          "translationRu": "Утром Бёрл находит мёртвую мотылька."
        },
        {
          "id": "sent-018",
          "text": "Toma sus alas y su pelaje suave.",
          "translationRu": "Он берёт её крылья и мягкий мех."
        }
      ]
    }
  ]
}
